# Cloned repos (created by corvia workspace init)
repos/corvia/

# corvia data directory — derived data excluded via .corvia/.gitignore
# entries/ and corvia.toml inside .corvia/ are trackable for team sharing.

# Local working files (per-user, not shared)
.local/
.devcontainer/.corvia-workspace-flags
.devcontainer/.task/
.devcontainer/.task-telemetry/
.devcontainer/docker-compose.override.yml

# Claude Code local settings (session-specific permissions)
.claude/settings.local.json

# Claude Code worktrees (ephemeral, created by agent subagent runs)
.claude/worktrees/

# Editor / IDE state (per-user)
.vscode/
.continue/

# Built VS Code extension artifacts (built from source by post-start.sh or CI)
*.vsix

# Python build artifacts
__pycache__/
*.egg-info/

# Node dependencies (install via package.json)
node_modules/

# Playwright MCP runtime logs
.playwright-mcp/

# Model caches (large, downloaded on demand)
.fastembed_cache/
.worktrees/
.superpowers/

# Plugin skill symlinks (created by install_claude_plugin, env-specific)
.agents/skills/superpowers
