{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "corvia hooks run --event PostToolUse",
            "timeout": 5000,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "corvia hooks run --event PostToolUse --handler write-reminder",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "corvia hooks run --event PreToolUse",
            "timeout": 5000,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "corvia hooks run --event PreToolUse --handler doc-placement",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "corvia hooks run --event PreToolUse --handler corvia-first-reminder",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Grep|Glob"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "corvia hooks run --event SessionEnd",
            "timeout": 30000,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "corvia hooks run --event SessionStart",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "corvia hooks run --event UserPromptSubmit",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ]
  }
}
