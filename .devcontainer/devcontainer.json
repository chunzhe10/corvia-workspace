{
    "name": "Corvia Demo Workspace",
    "build": {
        "dockerfile": "Dockerfile"
    },
    // GPU passthrough: uncomment the next line if you have NVIDIA GPU + nvidia-container-toolkit.
    // "runArgs": ["--gpus", "all"],
    //
    // Intel GPU passthrough (iGPU): uncomment the lines below if Intel GPU is available.
    // Required for OpenVINO execution provider on Intel integrated/discrete GPUs.
    // "runArgs": [
    //     "--device=/dev/dri",
    //     "--device=/dev/dxg",
    //     "--group-add", "video",
    //     "--group-add", "render"
    // ],
    "initializeCommand": ".devcontainer/scripts/init-host.sh",
    "postCreateCommand": ".devcontainer/scripts/post-create.sh",
    "postStartCommand": ".devcontainer/scripts/post-start.sh",
    "forwardPorts": [8020, 8021],
    "mounts": [
        "source=corvia-cargo-registry,target=/usr/local/cargo/registry,type=volume",
        "source=corvia-cargo-git,target=/usr/local/cargo/git,type=volume",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/root/.config/gh-host,type=bind,consistency=cached,readonly",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/root/.claude,type=bind,consistency=cached"
        // Uncomment for WSL2 GPU driver passthrough (Intel + NVIDIA):
        // "source=/usr/lib/wsl,target=/usr/lib/wsl,type=bind,readonly"
    ],
    "remoteUser": "root",
    "containerEnv": {
        "CORVIA_WORKSPACE": "${containerWorkspaceFolder}"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "Continue.continue"
            ],
            "settings": {
                "corvia.serverUrl": "http://localhost:8020",
                "rust-analyzer.server.extraEnv": {
                    "RUST_ANALYZER_MAX_MEMORY": "2048"
                },
                "rust-analyzer.files.excludeDirs": [
                    "target",
                    ".corvia",
                    ".git",
                    "node_modules"
                ],
                "files.watcherExclude": {
                    "**/target/**": true,
                    "**/.corvia/**": true,
                    "**/node_modules/**": true
                }
            }
        }
    }
}
