  "content": "pub fn all_passed(&self) -> bool {\n        self.results.iter().all(|r| r.passed())\n    }\npub fn pass_count(&self) -> usize {\n        self.results.iter().filter(|r| r.passed()).count()\n    }\npub fn fail_count(&self) -> usize {\n        self.results.iter().filter(|r| !r.passed()).count()\n    }",
