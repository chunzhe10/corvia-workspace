  "content": " => truncate_str(s, 50).to_string(),\n                        None => truncate_str(&v.to_string(), 50).to_string(),\n                    };\n                    return format!(\"{}={}\", k, val_str);\n                }\n            String::new()\n        }\n    }\n}\nfn truncate_str(s: &str, max: usize) -> &str {\n    if s.len() <= max {\n        s\n    } else {\n        // Find a char boundary\n        let mut end = max;\n        while end > 0 && !s.is_char_boundary(end) {\n            end -= 1;\n        }\n        &s[..end]\n    }\n}",
