  "content": "fn sessions_dir() -> PathBuf {\n    let home = std::env::var(\"HOME\").unwrap_or_else(|_| \"/root\".into());\n    PathBuf::from(home).join(\".claude\").join(\"sessions\")\n}\nfn extract_session_id(path: &Path) -> Option<String> {\n    path.file_stem()\n        .and_then(|s| s.to_str())\n        .map(|s| s.to_string())\n}",
