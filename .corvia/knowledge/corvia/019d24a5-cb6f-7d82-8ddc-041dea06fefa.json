{
  "id": "019d24a5-cb6f-7d82-8ddc-041dea06fefa",
  "content": "   entries: &[(String, Vec<f32>)],\n        k_min: usize,\n        k_max: usize,\n        labels: &std::collections::HashMap<String, String>,\n    ) -> Self {\n        Self::build_with_labels_and_rng(entries, k_min, k_max, labels, &mut rand::thread_rng())\n    }\npub fn build_with_labels_and_rng(\n        entries: &[(String, Vec<f32>)],\n        k_min: usize,\n        k_max: usize,\n        labels: &std::collections::HashMap<String, String>,\n        rng: &mut impl Rng,\n    ) -> Self {\n        let embeddings: Vec<Vec<f32>> = entries.iter().map(|(_, e)| e.clone()).collect();\n        let k_max = k_max.min(entries.len());\n        let k_min = k_min.min(k_max);\n\n        // L0: super-clusters\n        let best_k = find_best_k_with_rng(&embeddings, k_min, k_max, 500, rng);\n        let l0_assignments = kmeans_with_rng(&embeddings, best_k, 100, rng);\n\n        let mut super_clusters = Vec::new();\n        for c in 0..best_k {\n            let member_indices: Vec<usize> = l0_assignments\n                .iter()\n                .enumerate()\n                .filter(|&(_, a)| *a == c)\n                .map(|(i, _)| i)\n                .collect();\n            if member_indices.is_empty() {\n                continue;\n            }\n\n            let entry_ids: Vec<String> =\n                member_indices.iter().map(|&i| entries[i].0.clone()).collect();\n            let centroid = compute_centroid(\n                &member_indices\n                    .iter()\n                    .map(|&i| &embeddings[i])\n                    .collect::<Vec<_>>(),\n            );\n",
