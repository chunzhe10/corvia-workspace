  "id": "019d286a-f2d7-7750-81b8-2c1133ee2fe8",
  "content": "### Task 9: Update GitAdapter for D69 Trait\n\n    use corvia_kernel::chunking_fallback::FallbackChunker;\n    use std::sync::Arc;\n\n    let fallback = Arc::new(FallbackChunker::new(512));\n    let mut registry = FormatRegistry::new(fallback);\n\n    let adapter = GitAdapter::new();\n    adapter.register_chunking(&mut registry);\n\n    // After registration, .rs should resolve to \"ast\" not \"fallback\"\n    let strategy = registry.resolve(\"rs\");\n    assert_eq!(strategy.name(), \"ast\");\n}\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `cargo test -p corvia-adapter-git test_ingest_sources -- --nocapture`\nExpected: FAIL (method doesn't exist)\n\n**Step 3: Implement the new trait methods**\n\nReplace the `IngestionAdapter` impl on `GitAdapter`:\n\n```rust\n#[async_trait]\nimpl IngestionAdapter for GitAdapter {\n    fn domain(&self) -> &str {\n        \"git\"\n    }\n\n    fn register_chunking(&self, registry: &mut corvia_kernel::chunking_pipeline::FormatRegistry) {\n        use std::sync::Arc;\n        let ast = Arc::new(crate::ast_chunker::AstChunker::new());\n        for ext in ast.supported_extensions() {\n            registry.register_override(ext, ast.clone());\n        }",
