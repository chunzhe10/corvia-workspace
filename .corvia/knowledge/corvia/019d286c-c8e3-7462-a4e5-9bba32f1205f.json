{
  "id": "019d286c-c8e3-7462-a4e5-9bba32f1205f",
  "content": "lide\">\n  <div class=\"slide-label\">The Difference</div>\n  <div class=\"slide-title\">\n    Context Is<br>\n    <span class=\"highlight-cyan\">Everything.</span>\n  </div>\n  <div class=\"slide-subtitle\">\n    The model didn't change. The tools around it did.\n  </div>\n  <div style=\"display: flex; gap: 24px; margin-bottom: 28px;\">\n    <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-top: 4px solid var(--accent-red); text-align: center;\">\n      <div style=\"font-size: 36px; margin-bottom: 12px;\">&#128683;</div>\n      <h3 style=\"font-size: 22px; color: var(--accent-red); margin-bottom: 16px;\">Without Playwright</h3>\n      <div style=\"font-size: 20px; color: var(--text-secondary); line-height: 1.8; text-align: left;\">\n        &bull; Write code &rarr; hope it works<br>\n        &bull; Fix one thing &rarr; break another<br>\n        &bull; 3&ndash;5 rounds of back-and-forth<br>\n        &bull; Human becomes the \"eyes\"<br>\n        &bull; Tedious and frustrating\n      </div>\n    </div>\n    <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-top: 4px solid var(--accent-green); text-align: center;\">\n      <div style=\"font-size: 36px; margin-bottom: 12px;\">&#9989;</div>\n      <h3 style=\"font-size: 22px; color: var(--accent-green); margin-bottom: 16px;\">With Playwright</h3>\n      <div style=\"font-size: 20px; color: var(--text-secondary); line-height: 1.8; text-align: left;\">\n        &bull; Write &rarr; screenshot &rarr; verify<br>\n        &bull; Spots own mistakes first<br>\n        &bull; Self-correcting loop<br>\n        &bull; Human reviews final result<br>\n        &bull; Faster and autonomous\n      </div>\n    </div>\n  </div>\n\n  <div class=\"divider\"></div>",
