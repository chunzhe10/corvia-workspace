  "id": "019d286c-c8e3-7462-a4e5-a539d7c6e072",
  "content": "### Task 2.4: Create `GraphControls` component\n\n    onFilterChange({ contentRole: role, sourceOrigin: val, depth });\n  };\n\n  const handleDepthChange = (e: Event) => {\n    const val = parseInt((e.target as HTMLInputElement).value, 10);\n    setDepth(val);\n    onFilterChange({ contentRole: role, sourceOrigin: origin, depth: val });\n  };\n\n  return (\n    <div class=\"graph-controls\">\n      <select value={role ?? \"\"} onChange={handleRoleChange}>\n        <option value=\"\">All roles</option>\n        {availableRoles.map((r) => (\n          <option key={r} value={r}>{ROLE_LABELS[r] ?? r}</option>\n        ))}\n      </select>\n\n      <select value={origin ?? \"\"} onChange={handleOriginChange}>\n        <option value=\"\">All sources</option>\n        {availableOrigins.map((o) => (\n          <option key={o} value={o}>{o}</option>\n        ))}\n      </select>\n\n      <label class=\"depth-control\">\n        <span>Depth: {depth}</span>\n        <input\n          type=\"range\"\n          min={1}\n          max={3}\n          value={depth}\n          onInput={handleDepthChange}\n        />\n      </label>\n    </div>\n  );\n}\n```\n\n- [ ] **Step 2: Commit**\n\n```bash\ncd /workspaces/corvia-workspace\ngit add tools/corvia-dashboard/src/components/GraphControls.tsx\ngit commit -m \"feat(dashboard): add GraphControls component (depth slider + metadata filters)\"\n```\n\n---\n",
