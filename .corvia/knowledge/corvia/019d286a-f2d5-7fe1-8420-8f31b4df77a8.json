  "content": "fn is_executable(path: &Path) -> bool {\n    use std::os::unix::fs::PermissionsExt;\n    path.is_file()\n        && std::fs::metadata(path)\n            .map(|m| m.permissions().mode() & 0o111 != 0)\n            .unwrap_or(false)\n}\nfn home_dir() -> Option<PathBuf> {\n    std::env::var(\"HOME\").ok().map(PathBuf::from)\n}",
