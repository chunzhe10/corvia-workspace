  "content": "pub struct ClusterHierarchy {\n    pub super_clusters: Vec<ClusterNode>, // L0\n    pub sub_clusters: Vec<ClusterNode>,   // L1\n    pub entry_count: usize,\n    pub computed_at: chrono::DateTime<chrono::Utc>,\n}\nimpl ClusterHierarchy {\n    /// Build hierarchy from (entry_id, embedding) pairs.\n    /// Optional `labels` map resolves entry_ids to human-readable labels (source_file or content preview).\n    /// Without labels, entry IDs are used as cluster labels.\n    pub fn build(entries: &[(String, Vec<f32>)], k_min: usize, k_max: usize) -> Self {\n        Self::build_with_labels(entries, k_min, k_max, &std::collections::HashMap::new())\n    }\n\n    /// Build hierarchy with human-readable labels for clusters.\n    pub fn build_with_labels(\n        entries: &[(String, Vec<f32>)],\n        k_min: usize,\n        k_max: usize,\n        labels: &std::collections::HashMap<String, String>,\n    ) -> Self {\n        Self::build_with_labels_and_rng(entries, k_min, k_max, labels, &mut rand::thread_rng())\n    }\n\n    /// Build hierarchy with a caller-provided RNG (for deterministic tests).\n    pub fn build_with_labels_and_rng(\n        entries: &[(String, Vec<f32>)],\n        k_min: usize,\n        k_max: usize,\n        labels: &std::collections::HashMap<String, String>,\n        rng: &mut impl Rng,\n    ) -> Self {\n        let embeddings: Vec<Vec<f32>> = entries.iter().map(|(_, e)| e.clone()).collect();\n        let k_max = k_max.min(entries.len());\n        let k_min = k_min.min(k_max);\n\n        // L0: super-clusters\n        let best_k = find_best_k_with_rng(&embeddings, k_min, k_max, 500, rng);\n        let l0_assignments = kmeans_with_rng(&embeddings, best_k, 100, rng);\n\n        let mut super_clusters = Vec::new();\n        for c in 0..best_k {\n            let member_indices: Vec<usize> = l0_assignments\n                .iter()\n                .enumerate()\n                .filter(|&(_, a)| *a == c)\n                .map(|(i, _)| i)\n                .collect();\n            if member_indices.is_empty() {\n                continue;",
