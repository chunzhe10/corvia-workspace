  "content": "fn truncate_to_bytes(s: &str, max_bytes: usize) -> &str {\n    if s.len() <= max_bytes {\n        return s;\n    }\n    let mut end = max_bytes;\n    while end > 0 && !s.is_char_boundary(end) {\n        end -= 1;\n    }\n    &s[..end]\n}\nfn now_iso() -> String {\n    chrono::Utc::now().format(\"%Y-%m-%dT%H:%M:%S%.3fZ\").to_string()\n}",
