  "content": "            i += 2;\n                        continue;\n                    }\n                }\n            }\n\n            result.push(chunks[i].clone());\n            merge_flags.push(false);\n            i += 1;\n        }\n\n        (result, merge_flags)\n    }\nfn same_merge_group(a: &RawChunk, b: &RawChunk) -> bool {\n        match (&a.metadata.merge_group, &b.metadata.merge_group) {\n            (None, None) => true,\n            (Some(ga), Some(gb)) => ga == gb,\n            _ => false,\n        }\n    }",
