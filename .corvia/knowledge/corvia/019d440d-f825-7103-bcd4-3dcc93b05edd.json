  "content": "fn write_throttle_timestamp() {\n    let _ = fs::write(THROTTLE_FILE, format!(\"{}\", epoch_secs()));\n}\nfn epoch_secs() -> u64 {\n    std::time::SystemTime::now()\n        .duration_since(std::time::UNIX_EPOCH)\n        .unwrap_or_default()\n        .as_secs()\n}",
