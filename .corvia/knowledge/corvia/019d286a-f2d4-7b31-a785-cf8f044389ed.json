{
  "id": "019d286a-f2d4-7b31-a785-cf8f044389ed",
  "content": "   .unwrap_or(\"\")\n        .to_string();\n\n    // Skip lines with no useful content\n    if msg.is_empty() && target.is_empty() {\n        return None;\n    }\n\n    Some(ParsedTrace::Event {\n        level,\n        timestamp,\n        msg,\n        target,\n    })\n}\npub fn normalize_level(level: &str) -> &'static str {\n    match level.to_lowercase().as_str() {\n        \"warn\" | \"warning\" => \"warn\",\n        \"error\" | \"err\" => \"error\",\n        \"debug\" | \"trace\" => \"debug\",\n        _ => \"info\",\n    }\n}",
