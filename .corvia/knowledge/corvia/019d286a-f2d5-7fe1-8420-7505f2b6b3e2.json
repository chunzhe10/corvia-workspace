{
  "id": "019d286a-f2d5-7fe1-8420-7505f2b6b3e2",
  "content": " fields even without an external collector.\n    let tracer_provider;\n    let otel_layer = if !otlp_endpoint.is_empty() {\n        let exporter = opentelemetry_otlp::SpanExporter::builder()\n            .with_tonic()\n            .with_endpoint(&otlp_endpoint)\n            .build()?;\n\n        let provider = opentelemetry_sdk::trace::SdkTracerProvider::builder()\n            .with_batch_exporter(exporter)\n            .with_resource(\n                opentelemetry_sdk::Resource::builder()\n                    .with_service_name(service_name)\n                    .build(),\n            )\n            .build();\n\n        let tracer = provider.tracer(\"corvia\");\n        let layer = tracing_opentelemetry::layer().with_tracer(tracer);\n        tracer_provider = Some(provider);\n        Some(layer)\n    } else {\n        // Local-only provider: generates trace_id/span_id for structured\n        // logs without exporting to any external collector.\n        let provider = opentelemetry_sdk::trace::SdkTracerProvider::builder()\n            .with_resource(\n                opentelemetry_sdk::Resource::builder()\n                    .with_service_name(service_name)\n                    .build(),\n            )\n            .build();\n\n        let tracer = provider.tracer(\"corvia\");\n        let layer = tracing_opentelemetry::layer().with_tracer(tracer);\n        tracer_provider = Some(provider);\n        Some(layer)\n    };",
