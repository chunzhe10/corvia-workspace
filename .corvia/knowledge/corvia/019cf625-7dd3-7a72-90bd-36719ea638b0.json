  "content": "tyle=\"background: rgba(245, 158, 11, 0.15); color: var(--accent-amber);\">&#128737;</div>\n      <div class=\"flow-label highlight-amber\">Fallback</div>\n      <div class=\"flow-desc\">GPU missing?<br>Use CPU, but<br>log it. No silence.</div>\n    </div>\n  </div>\n  <!-- The key insight: visual -->\n  <div style=\"display: flex; gap: 20px; margin-bottom: 24px;\">\n    <div class=\"stat-box\" style=\"flex: 1; border-top: 4px solid var(--accent-blue);\">\n      <div style=\"font-size: 56px; font-weight: 900; color: var(--accent-blue);\">24</div>\n      <div style=\"font-size: 16px; color: var(--text-secondary); margin-top: 4px;\">unit tests covering<br>every backend path</div>\n    </div>\n    <div class=\"stat-box\" style=\"flex: 1; border-top: 4px solid var(--accent-green);\">\n      <div style=\"font-size: 56px; font-weight: 900; color: var(--accent-green);\">0</div>\n      <div style=\"font-size: 16px; color: var(--text-secondary); margin-top: 4px;\">config files needed<br>for GPU detection</div>\n    </div>\n    <div class=\"stat-box\" style=\"flex: 1; border-top: 4px solid var(--accent-amber);\">\n      <div style=\"font-size: 56px; font-weight: 900; color: var(--accent-amber);\">1</div>\n      <div style=\"font-size: 16px; color: var(--text-secondary); margin-top: 4px;\">binary handles<br>every backend</div>\n    </div>\n  </div>\n\n  <div class=\"insight-box\">\n    <p>fallback_used: true. No silent degradation.</p>\n  </div>\n\n  <div class=\"flex-grow\"></div>\n  <div class=\"author-tag\">Lim Chun Zhe</div>\n  <div class=\"slide-number\">04 / 08</div>\n</div>\n\n<!-- SLIDE 5: THE MESSY PART — visual with large numbers -->\n<div class=\"slide\">\n  <div class=\"slide-label\">The Messy Part</div>\n  <div class=\"slide-title\" style=\"margin-bottom: 48px;\">\n    \"Just Install<br>\n    <span class=\"highlight-red\">the Library\"</span>\n  </div>",
