  "content": "      ..Default::default()\n        };\n\n        // Agent only has access to scope-b, searching scope-a should return empty\n        let result = retriever.retrieve(\"query\", \"scope-a\", &opts).await.unwrap();\n        assert_eq!(result.results.len(), 0);\n    }\n\n    #[tokio::test]\n    async fn test_vector_retriever_visibility_own() {\n        let dir = tempfile::tempdir().unwrap();\n        let store = Arc::new(LiteStore::open(dir.path(), 3).unwrap()) as Arc<dyn QueryableStore>;\n        let engine = Arc::new(MockEngine) as Arc<dyn InferenceEngine>;\n        store.init_schema().await.unwrap();\n\n        let mut idx = 0_usize;\n        let mut next_emb = || { idx += 1; vec![1.0, idx as f32 * 0.001, 0.0] };\n\n        // Merged entry — always visible\n        let mut m = KnowledgeEntry::new(\"merged\".into(), \"proj\".into(), \"v1\".into())\n            .with_embedding(next_emb());\n        m.entry_status = EntryStatus::Merged;\n        store.insert(&m).await.unwrap();\n\n        // Pending by agent-A\n        let pa = KnowledgeEntry::new(\"pending A\".into(), \"proj\".into(), \"v1\".into())\n            .with_embedding(next_emb())\n            .with_agent(\"agent-A\".into(), \"sess-A\".into());\n        store.insert(&pa).await.unwrap();\n\n        // Pending by agent-B\n        let pb = KnowledgeEntry::new(\"pending B\".into(), \"proj\".into(), \"v1\".into())\n            .with_embedding(next_emb())\n            .with_agent(\"agent-B\".into(), \"sess-B\".into());\n        store.insert(&pb).await.unwrap();\n\n        // Filler\n        for i in 0..7 {\n            let mut f = KnowledgeEntry::new(format!(\"filler-{i}\"), \"proj\".into(), \"v1\".into())\n                .with_embedding(next_emb());\n            f.entry_status = EntryStatus::Merged;\n            store.insert(&f).await.unwrap();\n        }\n\n        let retriever = VectorRetriever::new(store, engine);\n        let opts = RetrievalOpts {\n            limit: 10,\n            visibility: VisibilityMode::Own,",
