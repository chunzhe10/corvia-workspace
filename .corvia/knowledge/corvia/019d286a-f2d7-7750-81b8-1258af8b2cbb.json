  "id": "019d286a-f2d7-7750-81b8-1258af8b2cbb",
  "content": "et(\"beta::baz\"), Some(&\"crates/beta/src/baz.rs\".to_string()));\n    }\n\n    #[test]\n    fn test_resolve_crate_internal() {\n        let dir = tempfile::tempdir().unwrap();\n        let root = dir.path();\n\n        fs::write(\n            root.join(\"Cargo.toml\"),\n            \"[package]\\nname = \\\"my-crate\\\"\\nversion = \\\"0.1.0\\\"\\nedition = \\\"2021\\\"\\n\",\n        ).unwrap();\n        fs::create_dir_all(root.join(\"src\")).unwrap();\n        fs::write(root.join(\"src/lib.rs\"), \"mod config;\\nmod utils;\\n\").unwrap();\n        fs::write(root.join(\"src/config.rs\"), \"pub struct Config {}\\n\").unwrap();\n        fs::create_dir_all(root.join(\"src/utils\")).unwrap();\n        fs::write(root.join(\"src/utils/mod.rs\"), \"\").unwrap();\n\n        let map = RustModuleMap::build(root);\n\n        // crate::config from src/lib.rs should resolve to src/config.rs\n        assert_eq!(\n            map.resolve(\"src/lib.rs\", \"crate::config\"),\n            Some(\"src/config.rs\".to_string())\n        );\n    }\n\n    #[test]\n    fn test_resolve_external_returns_none() {\n        let dir = tempfile::tempdir().unwrap();\n        let root = dir.path();\n\n        fs::write(\n            root.join(\"Cargo.toml\"),\n            \"[package]\\nname = \\\"my-crate\\\"\\nversion = \\\"0.1.0\\\"\\nedition = \\\"2021\\\"\\n\",\n        ).unwrap();\n        fs::create_dir_all(root.join(\"src\")).unwrap();\n        fs::write(root.join(\"src/lib.rs\"), \"\").unwrap();\n\n        let map = RustModuleMap::build(root);\n\n        // std::collections should return None (external crate)\n        assert_eq!(map.resolve(\"src/lib.rs\", \"std::collections\"), None);\n    }\n}\n```\n\n**Step 3: Register the module in `lib.rs`**\n\nIn `corvia-adapter-git/src/lib.rs`, add:\n```rust\npub mod module_resolver;\n```\nAnd add to the re-exports:\n```rust\npub use module_resolver::RustModuleMap;\n```\n\n**Step 4: Run the tests**\n\nRun: `cd /root/corvia-project/corvia-workspace/repos/corvia-adapter-git && cargo test module_resolver`\nExpected: All 5 tests pass.\n\n**Step 5: Commit**\n\n```bash\ngit add -A && git commit -m \"feat(m3.4): add RustModuleMap for cross-file import resolution (D72)\"\n```\n\n---\n",
