{
  "id": "019d286a-f2d5-7fe1-8420-98a6424cbfa6",
  "content": "pub fn new(url: &str, model: &str, dimensions: usize) -> Self {\n        Self {\n            url: url.to_string(),\n            model: model.to_string(),\n            dimensions,\n            client: reqwest::Client::new(),\n        }\n    }\npub async fn check_health(url: &str) -> bool {\n        let client = reqwest::Client::builder()\n            .timeout(std::time::Duration::from_secs(3))\n            .build()\n            .unwrap_or_default();\n        // Check if Ollama is reachable\n        if client.get(url).send().await.is_err() {\n            return false;\n        }\n        // Check if any models are available via /api/tags\n        let tags_url = format!(\"{}/api/tags\", url.trim_end_matches('/'));\n        match client.get(&tags_url).send().await {\n            Ok(resp) => {\n                if let Ok(json) = resp.json::<serde_json::Value>().await {\n                    json.get(\"models\")\n                        .and_then(|m| m.as_array())\n                        .map(|arr| !arr.is_empty())\n                        .unwrap_or(false)\n                } else {\n                    false\n                }\n            }\n            Err(_) => false,\n        }\n    }",
  "source_version": "crates/corvia-kernel/src/ollama_engine.rs",
