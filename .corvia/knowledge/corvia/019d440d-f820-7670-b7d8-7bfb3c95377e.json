  "content": "fn read_sysfs_string(path: &Path) -> Option<String> {\n    std::fs::read_to_string(path)\n        .ok()\n        .map(|s| s.trim().to_string())\n        .filter(|s| !s.is_empty())\n}\nfn read_sysfs_u64(path: &Path) -> Option<u64> {\n    read_sysfs_string(path).and_then(|s| s.parse::<u64>().ok())\n}",
