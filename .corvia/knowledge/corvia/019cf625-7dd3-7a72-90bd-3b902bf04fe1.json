  "content": "   </div>\n  );\n}\n```\n\n- [ ] **Step 2: Commit**\n\n```bash\ncd /workspaces/corvia-workspace\ngit add tools/corvia-dashboard/src/components/GraphControls.tsx\ngit commit -m \"feat(dashboard): add GraphControls component (depth slider + metadata filters)\"\n```\n\n---\n\n### Task 2.5: Create `NeighborCards` component\n\n**Files:**\n- Create: `tools/corvia-dashboard/src/components/NeighborCards.tsx`\n\n- [ ] **Step 1: Create clickable neighbor cards**\n\n```tsx\nimport type { NeighborEntry } from \"../types\";\n\n// Role → color mapping (matches graph node colors from spec)\nconst ROLE_COLORS: Record<string, string> = {\n  design: \"#7dd3fc\",    // blue\n  code: \"#5eead4\",      // green\n  plan: \"#ffb07c\",      // orange\n  memory: \"#c4b5fd\",    // purple\n  finding: \"#ff8a80\",   // red\n  decision: \"#f0c94c\",  // gold\n  instruction: \"#fcd34d\", // amber\n  learning: \"#6ee7b7\",  // emerald\n};\n\ninterface NeighborCardsProps {\n  neighbors: NeighborEntry[];\n  onSelect: (entryId: string) => void;\n}\n\nexport function NeighborCards({ neighbors, onSelect }: NeighborCardsProps) {\n  if (neighbors.length === 0) {\n    return <div class=\"neighbor-empty\">No connected entries</div>;\n  }\n\n  return (\n    <div class=\"neighbor-cards\">\n      <h4>Connected Knowledge</h4>\n      {neighbors.map((n) => (\n        <button\n          key={n.id}\n          class=\"neighbor-card\"\n          onClick={() => onSelect(n.id)}\n          title={`${n.relation} (${n.direction})`}\n        >\n          <span\n            class=\"role-dot\"\n            style={{ backgroundColor: ROLE_COLORS[n.content_role ?? \"\"] ?? \"#8a8279\" }}\n          />\n          <span class=\"neighbor-label\">\n            {n.source_file ?? n.content.slice(0, 60)}\n          </span>\n          <span class=\"neighbor-role\">{n.content_role ?? \"unknown\"}</span>\n        </button>\n      ))}\n    </div>\n  );\n}\n```\n\n- [ ] **Step 2: Commit**\n\n```bash\ncd /workspaces/corvia-workspace\ngit add tools/corvia-dashboard/src/components/NeighborCards.tsx\ngit commit -m \"feat(dashboard): add NeighborCards component for graph traversal from reader\"\n```\n\n---\n",
