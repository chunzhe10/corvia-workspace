{
  "id": "019d286a-f2d8-78b2-92cd-4492c1a82009",
  "content": "(|e| CorviaError::Storage(format!(\"Failed to create data dir: {e}\")))?;\n\n        let db_path = data_dir.join(\"metadata.redb\");\n        let db = Database::create(&db_path)\n            .map_err(|e| CorviaError::Storage(format!(\"Failed to open Redb: {e}\")))?;\n\n        // Load next_hnsw_id from Redb (or start at 0)\n        let next_id = {\n            let read_txn = db.begin_read()\n                .map_err(|e| CorviaError::Storage(format!(\"Redb read error: {e}\")))?;\n            if let Ok(table) = read_txn.open_table(META) {\n                table.get(\"next_hnsw_id\").ok().flatten()\n                    .map(|v| v.value())\n                    .unwrap_or(0)\n            } else {\n                0\n            }\n        };\n\n        let max_elements = 100_000;\n        let max_nb_connection = 24;\n        let nb_layer = 16;\n        let ef_construction = 400;\n\n        let hnsw = Hnsw::<f32, DistCosine>::new(\n            max_nb_connection,\n            max_elements,\n            nb_layer,\n            ef_construction,\n            DistCosine {},\n        );\n\n        let store = Self {\n            data_dir: data_dir.to_path_buf(),\n            db,\n            hnsw: Arc::new(Mutex::new(hnsw)),\n            next_hnsw_id: AtomicU64::new(next_id),\n            dimensions,\n        };\n\n        info!(\"LiteStore opened at {} (dim={dimensions})\", data_dir.display());\n        Ok(store)\n    }\n\n    fn allocate_hnsw_id(&self) -> u64 {\n        self.next_hnsw_id.fetch_add(1, Ordering::SeqCst)\n    }\n\n    fn persist_next_id(&self) -> Result<()> {\n        let write_txn = self.db.begin_write()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb write error: {e}\")))?;\n        {\n            let mut table = write_txn.open_table(META)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;",
