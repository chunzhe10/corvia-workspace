  "content": "ontext.contains(\"src/auth.rs\"));\n        assert!(ctx.context.contains(\"src/token.rs\"));\n        assert!(ctx.context.contains(\"How does auth work?\"));\n        assert_eq!(ctx.metrics.sources_included, 2);\n        assert_eq!(ctx.metrics.sources_truncated, 0);\n        assert_eq!(ctx.metrics.augmenter_name, \"structured\");\n    }\n\n    #[test]\n    fn test_structured_augmenter_respects_token_budget() {\n        let augmenter = StructuredAugmenter::new(None);\n        // Create a result with very long content\n        let long_content = \"x\".repeat(20000); // ~5000 tokens at chars/4\n        let results = vec![\n            mock_result(&long_content, 0.94, Some(\"big_file.rs\")),\n            mock_result(\"small entry\", 0.87, Some(\"small.rs\")),\n        ];\n        // Tiny budget — should truncate\n        let budget = TokenBudget { max_context_tokens: Some(100), reserve_for_answer: 0.0 };\n        let ctx = augmenter.augment(\"query\", &results, &budget).unwrap();\n\n        // At least one source should be truncated due to budget\n        assert!(ctx.metrics.sources_truncated > 0 || ctx.metrics.sources_included < 2);\n    }\n\n    #[test]\n    fn test_structured_augmenter_custom_system_prompt() {\n        let augmenter = StructuredAugmenter::new(Some(\"You are a security expert.\".into()));\n        let results = vec![mock_result(\"content\", 0.9, None)];\n        let budget = TokenBudget::default();\n        let ctx = augmenter.augment(\"query\", &results, &budget).unwrap();\n\n        assert_eq!(ctx.system_prompt, \"You are a security expert.\");\n    }\n\n    #[test]\n    fn test_structured_augmenter_empty_results() {",
