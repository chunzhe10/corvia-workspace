  "content": "### Task 1: Add `cuda` feature gate to corvia-inference\n### Task 2: Add `enable_cuda` function to corvia-workspace.sh\n\n# --- CUDA ---\n\n\n# Detect GPU info string for status display\ngpu_info() {\n    if command -v nvidia-smi &>/dev/null; then\n        nvidia-smi --query-gpu=name,driver_version,memory.total \\\n            --format=csv,noheader 2>/dev/null | head -1 | sed 's/, / /g'\n    else\n        echo \"not detected\"\n    fi\n}\n\ninstall_cuda_toolkit() {\n    echo \"  Installing CUDA toolkit (this may take a few minutes)...\"\n",
