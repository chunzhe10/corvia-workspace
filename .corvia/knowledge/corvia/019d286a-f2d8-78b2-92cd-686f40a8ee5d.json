  "id": "019d286a-f2d8-78b2-92cd-686f40a8ee5d",
  "content": "ce());\n        assert_eq!(loaded.workspace.unwrap().repos.len(), 1);\n    }\n\n    #[test]\n    fn test_resolve_repo_path_no_local() {\n        let repo = RepoConfig {\n            name: \"backend\".into(),\n            url: \"https://github.com/org/backend\".into(),\n            local: None,\n            namespace: \"backend\".into(),\n        };\n        let path = resolve_repo_path(Path::new(\"/workspace\"), \"repos\", &repo);\n        assert_eq!(path, PathBuf::from(\"/workspace/repos/backend\"));\n    }\n\n    #[test]\n    fn test_resolve_repo_path_local_exists() {\n        let dir = tempfile::tempdir().unwrap();\n        // Create a fake git repo at the local path\n        let local_path = dir.path().join(\"my-backend\");\n        std::fs::create_dir_all(local_path.join(\".git\")).unwrap();\n\n        let repo = RepoConfig {\n            name: \"backend\".into(),\n            url: \"https://github.com/org/backend\".into(),\n            local: Some(local_path.to_str().unwrap().into()),\n            namespace: \"backend\".into(),\n        };\n        let path = resolve_repo_path(Path::new(\"/workspace\"), \"repos\", &repo);\n        assert_eq!(path, local_path);\n    }\n\n    #[test]\n    fn test_resolve_repo_path_local_missing_falls_back() {\n        let repo = RepoConfig {\n            name: \"backend\".into(),\n            url: \"https://github.com/org/backend\".into(),\n            local: Some(\"/nonexistent/path\".into()),\n            namespace: \"backend\".into(),\n        };\n        let path = resolve_repo_path(Path::new(\"/workspace\"), \"repos\", &repo);\n        assert_eq!(path, PathBuf::from(\"/workspace/repos/backend\"));\n    }\n}\n```\n\n**Step 2: Add module declaration and dependencies**\n\nIn `main.rs`, add near the top:\n```rust\nmod workspace;\n```\n\nIn `crates/corvia-cli/Cargo.toml`, ensure `git2` and `tempfile` are present:\n```toml\n[dependencies]\ngit2 = \"0.19\"\n\n[dev-dependencies]\ntempfile = \"3\"\n```\n\n**Step 3: Run tests to verify they pass**\n\nRun: `cargo test -p corvia-cli -- workspace`\nExpected: all 8 tests PASS.\n\n**Step 4: Commit**\n\n```bash\ngit add crates/corvia-cli/src/workspace.rs crates/corvia-cli/src/main.rs crates/corvia-cli/Cargo.toml\ngit commit -m \"feat(m2.1): workspace module with scaffolding, repo resolution, config generation\"\n```\n\n---\n",
