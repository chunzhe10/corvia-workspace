{
  "id": "019d286a-f2d5-7fe1-8420-9629ec74a283",
  "content": "pub struct RagPipeline {\n    retriever: Arc<dyn Retriever>,\n    augmenter: Arc<dyn Augmenter>,\n    generator: Option<Arc<dyn GenerationEngine>>,\n    config: RagConfig,\n}\nimpl RagPipeline {\n    /// Create a new pipeline with the given stages and config.\n    pub fn new(\n        retriever: Arc<dyn Retriever>,\n        augmenter: Arc<dyn Augmenter>,\n        generator: Option<Arc<dyn GenerationEngine>>,\n        config: RagConfig,\n    ) -> Self {\n        Self {\n            retriever,\n            augmenter,\n            generator,\n            config,\n        }\n    }\n\n    /// Access the generation engine (if configured).\n    pub fn generator(&self) -> Option<&Arc<dyn GenerationEngine>> {\n        self.generator.as_ref()\n    }\n\n    /// Get the name of the active retriever (for config verification / tests).\n    pub fn retriever_name(&self) -> &str {\n        self.retriever.name()\n    }\n\n    /// Context-only mode: retrieve + augment, no generation.\n    #[tracing::instrument(name = \"corvia.rag.context\", skip(self, query, opts), fields(scope_id))]\n    pub async fn context(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: Option<RetrievalOpts>,\n    ) -> Result<RagResponse> {\n        self.run_pipeline(query, scope_id, opts, false).await\n    }\n\n    /// Full RAG: retrieve + augment + generate.\n    #[tracing::instrument(name = \"corvia.rag.ask\", skip(self, query, opts), fields(scope_id))]\n    pub async fn ask(\n        &self,\n        query: &str,",
