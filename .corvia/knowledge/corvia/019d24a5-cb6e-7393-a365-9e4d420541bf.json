  "id": "019d24a5-cb6e-7393-a365-9e4d420541bf",
  "content": "ncate_str(s: &str, max: usize) -> &str {\n    if s.len() <= max {\n        s\n    } else {\n        // Find a char boundary\n        let mut end = max;\n        while end > 0 && !s.is_char_boundary(end) {\n            end -= 1;\n        }\n        &s[..end]\n    }\n}\nfn read_lines_to_set(path: &Path) -> HashSet<String> {\n    std::fs::read_to_string(path)\n        .unwrap_or_default()\n        .lines()\n        .filter(|l| !l.trim().is_empty())\n        .map(String::from)\n        .collect()\n}",
