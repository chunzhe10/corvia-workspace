  "content": "fn test_cosine_similarity_identical() {\n        let a = vec![1.0, 0.0, 0.0];\n        let b = vec![1.0, 0.0, 0.0];\n        let sim = cosine_similarity(&a, &b);\n        assert!((sim - 1.0).abs() < 1e-6);\n    }\nfn test_cosine_similarity_orthogonal() {\n        let a = vec![1.0, 0.0];\n        let b = vec![0.0, 1.0];\n        let sim = cosine_similarity(&a, &b);\n        assert!(sim.abs() < 1e-6);\n    }",
