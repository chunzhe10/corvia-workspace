{
  "id": "019cf625-7dd3-7a72-90bd-32e7b776f3ab",
  "content": "\"card-header\" style=\"color: var(--accent-green);\">What AI does well</div>\n    <div style=\"font-size: 24px; line-height: 1.6;\">\n      Understands flexbox, grid, CSS variables. Writes clean HTML.\n      <strong>Technically fluent.</strong>\n    </div>\n  </div>\n  <div class=\"card\" style=\"border-left: 4px solid var(--accent-red);\">\n    <div class=\"card-header\" style=\"color: var(--accent-red);\">What AI can't do</div>\n    <div style=\"font-size: 24px; line-height: 1.6;\">\n      Open a browser. See the rendered page. Spot that text\n      overflowed or columns collapsed. <strong>It writes blind.</strong>\n    </div>\n  </div>\n\n  <div class=\"flex-grow\"></div>\n  <div class=\"author-tag\">Lim Chun Zhe</div>\n  <div class=\"slide-number\">02 / 08</div>\n</div>\n\n<!-- ════════════════════════════════════════════════ -->\n<!-- SLIDE 3: THE FAILURE MODE — ALIGNMENT           -->\n<!-- ════════════════════════════════════════════════ -->\n<div class=\"slide\">\n  <div class=\"slide-label\">The Failure Mode</div>\n  <div class=\"slide-title\">\n    Text Everywhere.<br>\n    <span class=\"highlight-red\">Nothing Aligned.</span>\n  </div>\n  <div class=\"slide-subtitle\">\n    The code looked correct, but the output was broken.\n  </div>",
