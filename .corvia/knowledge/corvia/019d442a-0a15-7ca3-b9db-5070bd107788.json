  "content": "margin-top: 12px;\">\n        <div style=\"font-size: 36px; font-weight: 900; color: var(--accent-cyan);\">51ms</div>\n        <div style=\"font-size: 14px; color: var(--text-secondary); margin-top: 2px;\">zero-copy &bull; shared bus</div>\n      </div>\n    </div>\n    <!-- VS divider -->\n    <div style=\"display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 0 4px;\">\n      <div style=\"width: 2px; flex: 1; background: linear-gradient(to bottom, transparent, var(--border), transparent);\"></div>\n      <div style=\"font-size: 22px; font-weight: 800; color: var(--text-muted); padding: 12px 0;\">VS</div>\n      <div style=\"width: 2px; flex: 1; background: linear-gradient(to bottom, transparent, var(--border), transparent);\"></div>\n    </div>\n\n    <!-- RIGHT COLUMN: dGPU path (PCIe copy) -->\n    <div style=\"flex: 1; display: flex; flex-direction: column; gap: 0; position: relative;\">\n      <!-- Column header -->\n      <div style=\"text-align: center; margin-bottom: 16px;\">\n        <div style=\"display: inline-block; padding: 6px 20px; border-radius: 20px; background: rgba(139,92,246,0.15); font-size: 14px; font-weight: 700; color: var(--accent-purple); letter-spacing: 2px; text-transform: uppercase;\">dGPU Path</div>\n      </div>\n\n      <!-- Input text -->\n      <div style=\"background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 14px 18px; text-align: center; font-size: 15px; font-weight: 600; color: var(--text-secondary);\">\n        Input text\n      </div>\n\n      <!-- Arrow down -->\n      <div style=\"display: flex; justify-content: center; padding: 6px 0;\">\n        <div style=\"width: 3px; height: 24px; background: var(--text-muted); border-radius: 2px; position: relative;\">\n          <div style=\"position: absolute; bottom: -6px; left: 50%; transform: translateX(-50%); width: 0; height: 0; border-left: 7px solid transparent; border-right: 7