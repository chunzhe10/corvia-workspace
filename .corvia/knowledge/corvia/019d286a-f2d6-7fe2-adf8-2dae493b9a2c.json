  "content": "e\n                }\n            })\n            .collect();\n\n        // Sort by score descending.\n        matches.sort_by(|a, b| b.score.partial_cmp(&a.score).unwrap_or(std::cmp::Ordering::Equal));\n        matches.truncate(max_skills);\n        matches\n    }\npub fn len(&self) -> usize {\n        self.skills.len()\n    }\npub fn is_empty(&self) -> bool {\n        self.skills.is_empty()\n    }",
