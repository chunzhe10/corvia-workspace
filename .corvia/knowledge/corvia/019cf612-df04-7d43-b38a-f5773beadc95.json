{
  "id": "019cf612-df04-7d43-b38a-f5773beadc95",
  "content": "pub fn span_to_module(span: &str) -> &'static str {\n    // Exact overrides\n    if span == \"corvia.entry.embed\" {\n        return \"inference\";\n    }\n\n    // Prefix matches (order matters — first match wins)\n    const PREFIX_MAP: &[(&str, &str)] = &[\n        (\"corvia.agent.\", \"agent\"),\n        (\"corvia.session.\", \"agent\"),\n        (\"corvia.entry.\", \"entry\"),\n        (\"corvia.merge.\", \"merge\"),\n        (\"corvia.store.\", \"storage\"),\n        (\"corvia.rag.\", \"rag\"),\n        (\"corvia.gc.\", \"gc\"),\n    ];\n\n    for (prefix, module) in PREFIX_MAP {\n        if span.starts_with(prefix) {\n            return module;\n        }\n    }\n\n    \"unknown\"\n}",
