  "content": " class=\"slide-number\">01 / 07</div>\n</div>\n\n<!-- Slide 2: THE SETUP -->\n<div class=\"slide\">\n  <div class=\"slide-label\">The Setup</div>\n  <div class=\"slide-title\">Linux for Engineering Was Working.<br><span class=\"highlight\">Now: Creative Work.</span></div>\n  <!-- 2x2 card grid for equal sizing -->\n  <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px;\">\n    <div class=\"card\" style=\"border-top: 3px solid var(--accent-green); padding: 28px; display: flex; align-items: flex-start; gap: 16px;\">\n      <div style=\"font-size: 36px; flex-shrink: 0;\">✅</div>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--accent-green); margin-bottom: 6px;\">Low RAM Baseline</div>\n        <div style=\"font-size: 20px; color: var(--text-secondary); line-height: 1.4;\">1GB idle vs 5GB on Windows. More headroom for creative apps.</div>\n      </div>\n    </div>\n    <div class=\"card\" style=\"border-top: 3px solid var(--accent-green); padding: 28px; display: flex; align-items: flex-start; gap: 16px;\">\n      <div style=\"font-size: 36px; flex-shrink: 0;\">✅</div>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--accent-green); margin-bottom: 6px;\">Native Docker</div>\n        <div style=\"font-size: 20px; color: var(--text-secondary); line-height: 1.4;\">No VM layer. Direct container access for development.</div>\n      </div>\n    </div>\n    <div class=\"card\" style=\"border-top: 3px solid var(--accent-green); padding: 28px; display: flex; align-items: flex-start; gap: 16px;\">\n      <div style=\"font-size: 36px; flex-shrink: 0;\">✅</div>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--accent-green); margin-bottom: 6px;\">iGPU Assignment</div>\n        <div style=\"font-size: 20px; color: var(--text-secondary); line-height: 1.4;\">DRI_P