  "content": "\n    pub total_chunks: usize,\n    pub chunks_split: usize,\n    pub chunks_merged: usize,\n    pub per_strategy: HashMap<String, StrategyStats>,\n}\n\n/// Per-strategy statistics.\n#[derive(Debug, Clone, Default)]\npub struct StrategyStats {\n    pub files: usize,\n    pub chunks: usize,\n    pub splits: usize,\n    pub merges: usize,\n}\n\n// ---- ChunkingPipeline ----\n\n/// Kernel orchestrator for the chunking framework (D65).\n///\n/// Steps: resolve strategy → chunk → merge small → enforce budget →\n/// split oversized → overlap context → emit ProcessedChunks.\npub struct ChunkingPipeline {\n    registry: FormatRegistry,\n    estimator: Arc<dyn TokenEstimator>,\n    config: ChunkingConfig,\n}\n\nimpl ChunkingPipeline {\n    pub fn new(\n        registry: FormatRegistry,\n        estimator: Arc<dyn TokenEstimator>,\n        config: ChunkingConfig,\n    ) -> Self {\n        Self { registry, estimator, config }\n    }\n\n    /// Process a single source file through the full pipeline.\n    pub fn process(\n        &self,\n        source: &str,\n        meta: &SourceMetadata,\n    ) -> Result<Vec<ProcessedChunk>> {\n        todo!()\n    }\n\n    /// Batch process multiple source files.\n    pub fn process_batch(\n        &self,\n        files: &[SourceFile],\n    ) -> Result<(Vec<ProcessedChunk>, ProcessingReport)> {\n        todo!()\n    }\n}",
