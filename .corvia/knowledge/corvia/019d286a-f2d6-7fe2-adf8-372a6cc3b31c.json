{
  "id": "019d286a-f2d6-7fe2-adf8-372a6cc3b31c",
  "content": "fn name(&self) -> &str {\n            \"line_chunker\"\n        }\nfn supported_extensions(&self) -> &[&str] {\n            &[\"txt\", \"log\"]\n        }\nfn chunk(&self, source: &str, meta: &SourceMetadata) -> Result<crate::chunking_strategy::ChunkResult> {\n            let chunks = source\n                .lines()\n                .enumerate()\n                .map(|(i, line)| RawChunk {\n                    content: line.to_string(),\n                    chunk_type: \"line\".into(),\n                    start_line: (i + 1) as u32,\n                    end_line: (i + 1) as u32,\n                    metadata: ChunkMetadata {\n                        source_file: meta.file_path.clone(),\n                        language: meta.language.clone(),\n                        ..Default::default()\n                    },\n                })\n                .collect();\n            Ok(crate::chunking_strategy::ChunkResult { chunks, relations: vec![] })\n        }",
  "source_version": "crates/corvia-kernel/src/chunking_pipeline.rs",
