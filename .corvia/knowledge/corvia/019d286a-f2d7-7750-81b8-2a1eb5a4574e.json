  "id": "019d286a-f2d7-7750-81b8-2a1eb5a4574e",
  "content": "### Task 1: FallbackChunker\n\n        assert_eq!(chunks[0].chunk_type, \"text\");\n    }\n\n    #[test]\n    fn test_paragraph_splitting() {\n        let chunker = FallbackChunker::new(10); // ~40 chars max\n        let source = \"Paragraph one content here.\\n\\nParagraph two content here.\\n\\nParagraph three.\";\n        let chunks = chunker.chunk(source, &meta()).unwrap();\n        assert!(chunks.len() >= 2, \"should split on paragraph boundaries, got {}\", chunks.len());\n        // Each chunk should fit within budget\n        for c in &chunks {\n            let estimate = c.content.len() / 4;\n            assert!(estimate <= 10 || c.content.len() <= 40,\n                \"chunk too large: {} chars\", c.content.len());\n        }\n    }\n\n    #[test]\n    fn test_line_splitting_fallback() {\n        let chunker = FallbackChunker::new(5); // ~20 chars max\n        // No paragraph breaks — falls back to line splitting\n        let source = \"line one here\\nline two here\\nline three here\\nline four here\";\n        let chunks = chunker.chunk(source, &meta()).unwrap();\n        assert!(chunks.len() >= 2, \"should split on line boundaries\");\n    }\n\n    #[test]\n    fn test_empty_source() {\n        let chunker = FallbackChunker::new(512);\n        let chunks = chunker.chunk(\"\", &meta()).unwrap();",
