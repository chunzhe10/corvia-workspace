{
  "id": "019d286a-f2d5-7fe1-8420-75ab8a185059",
  "content": "\n\n    fn keys(&self) -> Vec<&str> {\n        self.0\n            .keys()\n            .filter_map(|k| match k {\n                tonic::metadata::KeyRef::Ascii(key) => Some(key.as_str()),\n                _ => None,\n            })\n            .collect()\n    }\n}\nfn get(&self, key: &str) -> Option<&str> {\n        self.0.get(key).and_then(|v| v.to_str().ok())\n    }",
