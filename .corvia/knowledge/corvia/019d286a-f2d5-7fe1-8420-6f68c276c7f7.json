  "content": "        tracing::warn!(\n                    model = %name_owned,\n                    error = %e,\n                    \"Canary embedding task failed — model loaded but inference may not work\"\n                );\n            }\n        }\n\n        Ok(())\n    }\npub fn get_backend(&self, name: &str) -> Option<ResolvedBackend> {\n        self.models\n            .lock()\n            .ok()?\n            .get(name)\n            .map(|m| m.backend.clone())\n    }",
