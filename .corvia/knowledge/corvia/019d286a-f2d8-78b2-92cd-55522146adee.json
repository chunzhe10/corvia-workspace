  "content": "      let budget = TokenBudget::default();\n        let ctx = augmenter.augment(\"query\", &results, &budget).unwrap();\n\n        assert_eq!(ctx.system_prompt, \"You are a security expert.\");\n    }\n\n    #[test]\n    fn test_structured_augmenter_empty_results() {\n        let augmenter = StructuredAugmenter::new(None);\n        let budget = TokenBudget::default();\n        let ctx = augmenter.augment(\"query\", &[], &budget).unwrap();\n\n        assert_eq!(ctx.metrics.sources_included, 0);\n        assert!(ctx.context.contains(\"No relevant context found\"));\n    }\n}\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `cargo test -p corvia-kernel -- augmenter::tests --nocapture`\nExpected: FAIL — `StructuredAugmenter` not found\n\n**Step 3: Implement StructuredAugmenter**\n\nAdd between the trait definition and `#[cfg(test)]`:\n\n```rust\nconst DEFAULT_SYSTEM_PROMPT: &str = \"You are a knowledge assistant for an organization. \\\nAnswer questions using ONLY the provided context. Cite sources using [N] notation. \\\nIf the context does not contain enough information, say so.\";\n\n/// Estimate token count using chars/4 heuristic.\nfn estimate_tokens(text: &str) -> usize {\n    text.len() / 4\n}\n\n/// Structured context augmenter with source citations and token budget.\npub struct StructuredAugmenter {\n    system_prompt: String,\n}",
