  "content": "iv class=\"slide\">\n  <div class=\"slide-label\" style=\"color: var(--accent-red);\">The Adversary</div>\n  <div class=\"slide-title\"><span class=\"highlight-red\">Wayland + Ubuntu 24.04</span></div>\n  <div class=\"slide-subtitle\">One Root Cause. Many Symptoms.</div>\n  <!-- Symptom blocks - bigger cards with more detail -->\n  <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;\">\n    <div class=\"symptom-block\" style=\"border-left: 4px solid var(--accent-red); padding: 28px;\">\n      <span style=\"font-size: 32px;\">💥</span>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;\">Dependency conflicts</div>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.4;\">Bundled vs system libraries. Resolve ships its own, Ubuntu has different versions.</div>\n      </div>\n    </div>\n    <div class=\"symptom-block\" style=\"border-left: 4px solid var(--accent-amber); padding: 28px;\">\n      <span style=\"font-size: 32px;\">🔗</span>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;\">Library mismatches</div>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.4;\">Renamed with t64 suffixes. Package names changed under Resolve's feet.</div>\n      </div>\n    </div>\n    <div class=\"symptom-block\" style=\"border-left: 4px solid var(--accent-red); padding: 28px;\">\n      <span style=\"font-size: 32px;\">🖥️</span>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;\">GPU errors</div>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.4;\">Misleading error messages. Pointed at memory when the real issue was elsewhere.</div>\n      </div>\n    </div>\n    <div class=\"symptom-block\" style=\"border-left: 4px solid var(--accent-amber); padding: 28px;\">\n      <span style=\"font-size: 32px;\">📦</span>\n      <div style=\"min-width: 0;\">\n        <div style=\"font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;\">Missing packages</div>",
