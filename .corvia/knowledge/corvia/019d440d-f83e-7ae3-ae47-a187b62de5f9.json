pan class=\"stat-value\" style={{ color: \"var(--coral)\" }}>\n                {selectedSpans.reduce((s, [, st]) => s + st.errors, 0)}\n              </span>\n            </div>\n          </div>\n\n          {selectedSpans.length > 0 && (\n            <div class=\"detail-card\">",
