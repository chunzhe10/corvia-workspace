{
  "id": "019cf612-df05-7932-9104-ae772a32abb0",
  "content": "ckend {\n            device: Device::Cpu,\n            backend: BackendKind::Cpu,\n            fallback_used: false,\n        }),\n        other => Err(format!(\n            \"Unknown backend: '{other}'. Expected 'cuda', 'openvino', or 'cpu'.\"\n        )),\n    }\n}\nfn resolve_gpu_preferred(\n    model_type: ModelType,\n    gpu: &GpuCapabilities,\n) -> Result<ResolvedBackend, String> {\n    // Prefer CUDA\n    if gpu.cuda_available {\n        return Ok(ResolvedBackend {\n            device: Device::Gpu,\n            backend: BackendKind::Cuda,\n            fallback_used: false,\n        });\n    }\n\n    // Then OpenVINO (embedding only)\n    if gpu.openvino_available && model_type == ModelType::Embedding {\n        return Ok(ResolvedBackend {\n            device: Device::Gpu,\n            backend: BackendKind::OpenVino,\n            fallback_used: false,\n        });\n    }\n\n    // Fallback to CPU\n    Ok(ResolvedBackend {\n        device: Device::Cpu,\n        backend: BackendKind::Cpu,\n        fallback_used: true,\n    })\n}",
  "source_version": "crates/corvia-inference/src/backend.rs",
