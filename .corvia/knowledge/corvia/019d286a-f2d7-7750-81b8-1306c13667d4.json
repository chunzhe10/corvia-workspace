{
  "id": "019d286a-f2d7-7750-81b8-1306c13667d4",
  "content": "_extract_code_span_references() {\n    let source = \"# Storage\\n\\nThe `QueryableStore` trait defines the interface.\\n\";\n    let meta = SourceMetadata {\n        file_path: \"docs/storage.md\".into(),\n        extension: \"md\".into(),\n        ..Default::default()\n    };\n    let chunker = MarkdownChunker::new();\n    let result = chunker.chunk(source, &meta).unwrap();\n    assert!(!result.relations.is_empty(), \"Should extract QueryableStore reference\");\n    let rel = &result.relations[0];\n    assert_eq!(rel.relation, \"references\");\n    assert_eq!(rel.to_name, Some(\"QueryableStore\".to_string()));\n}\n\n#[test]\nfn test_extract_link_references() {\n    let source = \"# Traits\\n\\nSee [the traits file](src/traits.rs) for details.\\n\";\n    let meta = SourceMetadata {\n        file_path: \"docs/overview.md\".into(),\n        extension: \"md\".into(),\n        ..Default::default()\n    };\n    let chunker = MarkdownChunker::new();\n    let result = chunker.chunk(source, &meta).unwrap();\n    let file_refs: Vec<_> = result.relations.iter().filter(|r| !r.to_file.is_empty()).collect();\n    assert!(!file_refs.is_empty(), \"Should extract file path reference\");\n    assert!(file_refs[0].to_file.contains(\"traits.rs\"));\n}\n\n#[test]\nfn test_skip_common_types() {\n    let source = \"# Types\\n\\nUse `String` and `Vec` for collections. Use `QueryableStore` for storage.\\n\";\n    let meta = SourceMetadata {\n        file_path: \"docs/types.md\".into(),\n        extension: \"md\".into(),\n        ..Default::default()\n    };\n    let chunker = MarkdownChunker::new();\n    let result = chunker.chunk(source, &meta).unwrap();",
