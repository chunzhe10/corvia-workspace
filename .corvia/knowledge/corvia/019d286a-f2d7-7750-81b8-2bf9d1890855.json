  "content": "se ast_chunker::AstChunker;\n```\n\nRun: `cargo test -p corvia-adapter-git ast_chunker -- --nocapture`\nExpected: FAIL (todo!() panics)\n\n**Step 3: Implement AstChunker**\n\nDelegate to existing `treesitter::chunk_file()`, converting `CodeChunk`s to `RawChunk`s:\n\n```rust\nimpl ChunkingStrategy for AstChunker {\n    fn name(&self) -> &str { \"ast\" }\n\n    fn supported_extensions(&self) -> &[&str] {\n        &[\"rs\", \"js\", \"jsx\", \"ts\", \"tsx\", \"py\"]\n    }\n\n    fn chunk(&self, source: &str, meta: &SourceMetadata) -> Result<Vec<RawChunk>> {\n        let code_chunks = treesitter::chunk_file(&meta.file_path, source, &meta.extension);\n        let raw_chunks = code_chunks\n            .into_iter()\n            .map(|cc| RawChunk {\n                content: cc.content,\n                chunk_type: cc.chunk_type,\n                start_line: cc.start_line,\n                end_line: cc.end_line,\n                metadata: ChunkMetadata {\n                    source_file: cc.file_path,\n                    language: Some(cc.language),\n                    ..Default::default()\n                },\n            })\n            .collect();\n        Ok(raw_chunks)\n    }\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\nRun: `cargo test -p corvia-adapter-git ast_chunker -- --nocapture`\nExpected: All tests PASS\n\n**Step 5: Commit**\n\n```bash\ngit add corvia-adapter-git/src/ast_chunker.rs corvia-adapter-git/src/lib.rs\ngit commit -m \"feat(m3.3): AstChunker — tree-sitter ChunkingStrategy adapter (D65/D68)\"\n```\n\n---\n",
