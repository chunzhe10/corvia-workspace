  "id": "019d286c-c8e3-7462-a4e5-9c86d38195b0",
  "content": "   border-radius: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 20px;\n    font-weight: 800;\n    flex-shrink: 0;\n  }\n\n  .step-content h3 {\n    font-size: 20px;\n    font-weight: 700;\n    margin-bottom: 6px;\n  }\n  .step-content p {\n    font-size: 16px;\n    color: var(--text-secondary);\n    line-height: 1.5;\n  }\n\n  /* ── Terminal ── */\n  .terminal {\n    background: #0d1117;\n    border: 1px solid #30363d;\n    border-radius: 12px;\n    padding: 24px;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 16px;\n    line-height: 1.8;\n    margin: 16px 0;\n  }\n\n  .terminal .prompt { color: var(--accent-green); }\n  .terminal .cmd { color: var(--text-primary); }\n  .terminal .output { color: var(--text-secondary); }\n  .terminal .highlight-val { color: var(--accent-amber); }\n\n  /* ── Pill tags ── */\n  .tag {\n    display: inline-block;\n    padding: 6px 16px;\n    border-radius: 20px;\n    font-size: 14px;\n    font-weight: 600;\n    margin-right: 8px;\n    margin-bottom: 8px;\n  }\n\n  /* ── GPU diagram ── */\n  .gpu-diagram {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 32px;\n    margin: 24px 0;\n  }\n\n  .gpu-box {\n    background: var(--bg-card);\n    border: 2px solid var(--border);\n    border-radius: 16px;\n    padding: 24px 32px;\n    text-align: center;\n    min-width: 200px;\n  }\n\n  .gpu-box h4 {\n    font-size: 16px;\n    font-weight: 700;\n    margin-bottom: 8px;\n  }\n\n  .gpu-box .gpu-usage {\n    font-size: 36px;\n    font-weight: 800;\n  }\n\n  .arrow-right {\n    font-size: 32px;\n    color: var(--accent-green);\n  }\n\n  /* ── Divider ── */\n  .divider {\n    height: 1px;\n    background: var(--border);\n    margin: 28px 0;\n  }\n\n  .flex-grow { flex: 1; }\n\n  /* ── Cover specific ── */\n  .cover-center {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .cover-emoji {\n    font-size: 72px;\n    margin-bottom: 32px;\n  }\n\n  .cover-tags {\n    margin-top: 40px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 12px;\n  }\n\n  .cover-tags .tag {\n    background: rgba(59, 130, 246, 0.15);\n    color: var(--accent-blue);\n    font-size: 16px;\n    padding: 10px 20px;\n  }",
