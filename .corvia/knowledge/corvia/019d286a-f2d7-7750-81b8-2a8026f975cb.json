  "content": ") -> Result<Vec<ProcessedChunk>> {\n        todo!()\n    }\n\n    /// Batch process multiple source files.\n    pub fn process_batch(\n        &self,\n        files: &[SourceFile],\n    ) -> Result<(Vec<ProcessedChunk>, ProcessingReport)> {\n        todo!()\n    }\n}\n```\n\nTests to add in the same file:\n\n```rust\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use crate::chunking_fallback::FallbackChunker;\n\n    fn default_config() -> ChunkingConfig {\n        ChunkingConfig {\n            max_tokens: 512,\n            min_tokens: 32,\n            overlap_tokens: 0, // disable overlap for most tests\n            strategy: \"auto\".into(),\n        }\n    }\n\n    fn make_pipeline(config: ChunkingConfig) -> ChunkingPipeline {\n        let fallback = Arc::new(FallbackChunker::new(config.max_tokens));\n        let registry = FormatRegistry::new(fallback);\n        let estimator = Arc::new(CharDivFourEstimator) as Arc<dyn TokenEstimator>;\n        ChunkingPipeline::new(registry, estimator, config)\n    }\n\n    fn test_meta(ext: &str) -> SourceMetadata {\n        SourceMetadata {\n            file_path: format!(\"test.{ext}\"),\n            extension: ext.into(),\n            language: None,\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    // -- FormatRegistry tests --\n\n    #[test]\n    fn test_registry_resolve_fallback() {\n        let fallback = Arc::new(FallbackChunker::new(512));\n        let registry = FormatRegistry::new(fallback);\n        let resolved = registry.resolve(\"xyz\");\n        assert_eq!(resolved.name(), \"fallback\");",
