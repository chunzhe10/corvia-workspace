  "content": "fn is_markdown(path: &str) -> bool {\n    path.ends_with(\".md\") || path.ends_with(\".mdx\") || path.ends_with(\".rst\")\n}\nfn glob_match(path: &str, pattern: &str) -> bool {\n    if let Some(prefix) = pattern.strip_suffix('*') {\n        path.starts_with(prefix)\n    } else {\n        path == pattern\n    }\n}",
