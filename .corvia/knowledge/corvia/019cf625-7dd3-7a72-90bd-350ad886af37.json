{
  "id": "019cf625-7dd3-7a72-90bd-350ad886af37",
  "content": " <div class=\"slide-title\">\n    Windows vs WSL vs<br>\n    <span class=\"highlight-cyan\">Native Linux</span>\n  </div>\n  <div class=\"slide-subtitle\" style=\"font-size: 20px;\">\n    I needed Docker for VS Code Devcontainers. Here's the cost of each path.\n  </div>\n  <div style=\"display: flex; gap: 16px; margin-bottom: 24px;\">\n    <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-top: 4px solid var(--accent-blue); text-align: center;\">\n      <div style=\"font-size: 32px; margin-bottom: 8px;\">&#127466;&#127468;</div>\n      <h3 style=\"font-size: 18px; color: var(--accent-blue); margin-bottom: 12px;\">Windows + Docker Desktop</h3>\n      <div style=\"font-size: 14px; color: var(--text-secondary); line-height: 1.6;\">\n        Hyper-V VM layer<br>\n        Docker Desktop overhead<br>\n        Windows services in background\n      </div>\n      <div style=\"margin-top: 16px;\">\n        <span style=\"font-size: 36px; font-weight: 800; color: var(--accent-red);\">6&ndash;8 GB</span><br>\n        <span style=\"font-size: 14px; color: var(--text-muted);\">with default settings</span>\n      </div>\n    </div>\n    <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-top: 4px solid var(--accent-amber); text-align: center;\">\n      <div style=\"font-size: 32px; margin-bottom: 8px;\">&#128736;</div>\n      <h3 style=\"font-size: 18px; color: var(--accent-amber); margin-bottom: 12px;\">Windows + WSL2</h3>\n      <div style=\"font-size: 14px; color: var(--text-secondary); line-height: 1.6;\">\n        Lightweight VM (default Docker backend)<br>\n        Shared kernel, but still virtualized<br>\n        vmmem can leak memory over time\n      </div>\n      <div style=\"margin-top: 16px;\">\n        <span style=\"font-size: 36px; font-weight: 800; color: var(--accent-amber);\">~6 GB</span><br>\n        <span style=\"font-size: 14px; color: var(--text-muted);\">Windows + WSL VM overhead</span>\n      </div>\n    </div>\n    <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-top: 4px solid var(--accent-green); text-align: center;\">\n      <div style=\"font-size: 32px; margin-bottom: 8px;\">&#128039;</div>\n      <h3 style=\"font-size: 18px; color: var(--accent-green); margin-bottom: 12px;\">Native Ubuntu Linux</h3>\n      <div style=\"font-size: 14px; color: var(--text-secondary); line-height: 1.6;\">",
