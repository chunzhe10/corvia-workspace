  "id": "019d24a5-cb6e-7393-a365-ac9d74ab106f",
  "content": "struct NewLines {\n    lines: Vec<String>,\n    new_offset: u64,\n    last_event_type: Option<String>,\n}\nfn read_new_lines(path: &Path, offset: u64) -> NewLines {\n    let mut result = NewLines {\n        new_offset: offset,\n        ..Default::default()\n    };\n\n    let mut file = match std::fs::File::open(path) {\n        Ok(f) => f,\n        Err(_) => return result,\n    };\n\n    let file_len = file.metadata().map(|m| m.len()).unwrap_or(0);\n    if file_len <= offset {\n        return result;\n    }\n\n    if file.seek(SeekFrom::Start(offset)).is_err() {\n        return result;\n    }\n\n    let reader = BufReader::new(&file);\n    let mut byte_pos = offset;\n\n    for line_result in reader.lines() {\n        let line = match line_result {\n            Ok(l) => l,\n            Err(_) => break, // I/O error or invalid UTF-8 — stop here\n        };\n\n        // Account for the line content + the \\n delimiter.\n        let line_bytes = line.len() as u64 + 1; // +1 for \\n\n        byte_pos += line_bytes;\n\n        // Skip empty lines.\n        if line.is_empty() {\n            result.new_offset = byte_pos;",
  "source_version": "crates/corvia-server/src/dashboard/session_watcher.rs",
