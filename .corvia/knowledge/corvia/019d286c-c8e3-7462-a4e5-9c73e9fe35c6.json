{
  "id": "019d286c-c8e3-7462-a4e5-9c73e9fe35c6",
  "content": "--border);\n  }\n\n  .comparison-table td {\n    padding: 22px 24px;\n    font-size: 20px;\n    font-weight: 500;\n    background: var(--bg-card);\n    border-bottom: 1px solid var(--border);\n  }\n\n  .comparison-table tr:last-child td {\n    border-bottom: none;\n  }\n  .os-icon {\n    display: inline-block;\n    width: 36px;\n    height: 36px;\n    border-radius: 8px;\n    text-align: center;\n    line-height: 36px;\n    font-size: 18px;\n    margin-right: 12px;\n    vertical-align: middle;\n  }\n\n  /* ── Bar chart ── */\n  .bar-chart {\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n    margin: 24px 0;\n  }\n\n  .bar-row {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .bar-label {\n    width: 120px;\n    font-size: 18px;\n    font-weight: 600;\n    text-align: right;\n    flex-shrink: 0;\n  }\n\n  .bar-track {\n    flex: 1;\n    height: 48px;\n    background: var(--bg-card);\n    border-radius: 12px;\n    overflow: hidden;\n    position: relative;\n  }\n\n  .bar-fill {\n    height: 100%;\n    border-radius: 12px;\n    display: flex;\n    align-items: center;\n    padding-left: 16px;\n    font-size: 18px;\n    font-weight: 700;\n    color: white;\n    min-width: 80px;\n  }\n\n  /* ── Stat boxes ── */\n  .stat-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin: 24px 0;\n  }\n\n  .stat-box {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 28px;\n    text-align: center;\n  }\n\n  .stat-value {\n    font-size: 48px;\n    font-weight: 800;\n    margin-bottom: 8px;\n  }\n\n  .stat-label {\n    font-size: 16px;\n    font-weight: 500;\n    color: var(--text-secondary);\n  }\n\n  /* ── Flow / Steps ── */\n  .step-list {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n  }\n\n  .step-item {\n    display: flex;\n    align-items: flex-start;\n    gap: 20px;\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 24px;\n  }\n\n  .step-num {\n    width: 44px;\n    height: 44px;\n    border-radius: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 20px;\n    font-weight: 800;\n    flex-shrink: 0;\n  }\n\n  .step-content h3 {\n    font-size: 20px;\n    font-weight: 700;\n    margin-bottom: 6px;\n  }",
