  "content": "   <div style=\"background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); border-radius: 14px; padding: 22px 20px; font-size: 20px; font-weight: 600; flex: 1; text-align: center;\">\n        &#9989; Verify fix\n      </div>\n    </div>\n  </div>\n  <div class=\"terminal\">\n    <span class=\"output\">// .mcp.json</span><br>\n    <span class=\"cmd\">{</span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;\"mcpServers\": {</span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"highlight-val\">\"playwright\"</span>: {</span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"command\": \"npx\",</span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"args\": [<span class=\"highlight-val\">\"@playwright/</span></span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"highlight-val\">mcp@latest\"</span>]</span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;&nbsp;&nbsp;}</span><br>\n    <span class=\"cmd\">&nbsp;&nbsp;}</span><br>\n    <span class=\"cmd\">}</span>\n  </div>\n\n  <div class=\"card\" style=\"border-left: 4px solid var(--accent-green);\">\n    <div style=\"font-size: 24px; line-height: 1.6;\">\n      <strong>Same AI, same code generation.</strong> Now it can see\n      what it produces and fix it &mdash; just like a human would.\n    </div>\n  </div>\n\n  <div class=\"flex-grow\"></div>\n  <div class=\"author-tag\">Lim Chun Zhe</div>\n  <div class=\"slide-number\">06 / 08</div>\n</div>\n\n<!-- ════════════════════════════════════════════════ -->\n<!-- SLIDE 7: THE DIFFERENCE                         -->\n<!-- ════════════════════════════════════════════════ -->\n<div class=\"slide\">\n  <div class=\"slide-label\">The Difference</div>\n  <div class=\"slide-title\">\n    Context Is<br>\n    <span class=\"highlight-cyan\">Everything.</span>\n  </div>\n  <div class=\"slide-subtitle\">\n    The model didn't change. The tools around it did.\n  </div>",
