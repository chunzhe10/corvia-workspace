  "content": "   fn drop(&mut self) {\n        if let Err(e) = self.flush_hnsw() {\n            tracing::warn!(error = %e, \"LiteStore: failed to flush HNSW on drop\");\n        } else {\n            tracing::info!(\"LiteStore: HNSW index persisted to disk\");\n        }\n    }\n}\nfn drop(&mut self) {\n        if let Err(e) = self.flush_hnsw() {\n            tracing::warn!(error = %e, \"LiteStore: failed to flush HNSW on drop\");\n        } else {\n            tracing::info!(\"LiteStore: HNSW index persisted to disk\");\n        }\n    }",
