{
  "id": "019d286a-f2d5-7fe1-8420-815815aa9e4a",
  "content": "async fn edges(\n        &self,\n        entry_id: &uuid::Uuid,\n        direction: corvia_common::types::EdgeDirection,\n    ) -> Result<Vec<corvia_common::types::GraphEdge>> {\n        self.graph.edges(entry_id, direction).await\n    }\nasync fn traverse(\n        &self,\n        start: &uuid::Uuid,\n        relation: Option<&str>,\n        direction: corvia_common::types::EdgeDirection,\n        max_depth: usize,\n    ) -> Result<Vec<KnowledgeEntry>> {\n        let ids = self.graph.traverse_ids(start, relation, direction, max_depth)?;\n        let mut entries = Vec::new();\n        for id in ids {\n            if let Some(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(entries)\n    }",
