{
  "id": "019d286a-f2d5-7fe1-8420-6cb9519a8c16",
  "content": " = model\n        .new_context(llama_backend(), ctx_params)\n        .map_err(|e| Status::internal(format!(\"Context creation failed: {e}\")))?;\n\n    // Build sampler chain\n    let temperature = if params.temperature <= 0.0 {\n        0.0 // greedy\n    } else {\n        params.temperature\n    };\n\n    let mut sampler = if temperature == 0.0 {\n        LlamaSampler::chain_simple([\n            LlamaSampler::min_p(0.05, 1),\n            LlamaSampler::greedy(),\n        ])\n    } else {\n        LlamaSampler::chain_simple([\n            LlamaSampler::min_p(0.05, 1),\n            LlamaSampler::temp(temperature),\n            LlamaSampler::dist(42),\n        ])\n    };\n\n    // Feed the prompt tokens in chunks of n_batch to avoid exceeding batch size\n    let n_batch = 512;\n    let mut batch = LlamaBatch::new(n_batch, 1);\n    let mut i = 0;\n    while i < n_prompt {\n        batch.clear();\n        let end = (i + n_batch).min(n_prompt);\n        for (j, &token) in prompt_tokens[i..end].iter().enumerate() {\n            let pos = i + j;\n            let is_last = pos == n_prompt - 1;\n            batch\n                .add(token, pos as i32, &[0], is_last)\n                .map_err(|e| Status::internal(format!(\"Batch add failed: {e}\")))?;\n        }\n        ctx.decode(&mut batch)\n            .map_err(|e| Status::internal(format!(\"Prompt decode failed: {e}\")))?;",
  "source_version": "crates/corvia-inference/src/chat_service.rs",
