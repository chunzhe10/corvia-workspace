  "content": "kendKind::Cpu],\n        BackendKind::OpenVino => &[BackendKind::Cpu],\n        BackendKind::Cpu => &[],\n    };\n    for &fb in fallbacks {\n        if fb == BackendKind::Cpu || verify_ep_available(&fb) {\n            chain.push(fb);\n        }\n    }\n    chain\n}\nfn can_dlopen(lib_name: &str) -> bool {\n    use std::ffi::CString;\n    let name = CString::new(lib_name).unwrap();\n    // RTLD_LAZY: resolve symbols on first use (matches ORT behavior)\n    let handle = unsafe { libc::dlopen(name.as_ptr(), libc::RTLD_LAZY) };\n    if handle.is_null() {\n        false\n    } else {\n        unsafe { libc::dlclose(handle) };\n        true\n    }\n}",
