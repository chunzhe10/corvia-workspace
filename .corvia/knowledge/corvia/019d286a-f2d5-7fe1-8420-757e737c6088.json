  "content": "impl Injector for MetadataInjector<'_> {\n    fn set(&mut self, key: &str, value: String) {\n        if let Ok(name) = tonic::metadata::MetadataKey::from_bytes(key.as_bytes())\n            && let Ok(val) = value.parse() {\n                self.0.insert(name, val);\n            }\n    }\n}",
