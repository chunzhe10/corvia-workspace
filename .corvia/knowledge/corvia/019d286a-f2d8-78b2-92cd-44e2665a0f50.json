  "content": "### Step 5: Implement QueryableStore trait\n\n        let fetch_count = (limit * 2).max(10);\n        let ef_search = 64.max(fetch_count);\n\n        let neighbours = {\n            let hnsw = self.hnsw.lock().unwrap();\n            hnsw.search(&embedding.to_vec(), fetch_count, ef_search)\n        };\n\n        let read_txn = self.db.begin_read()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb read error: {e}\")))?;\n        let h2u_table = read_txn.open_table(HNSW_TO_UUID)\n            .map_err(|e| CorviaError::Storage(e.to_string()))?;\n        let entries_table = read_txn.open_table(ENTRIES)\n            .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n        let mut results = Vec::new();\n        for neighbour in &neighbours {\n            // NOTE: Verify these field names against hnsw_rs docs.\n            // The Neighbour struct likely has d_id (usize) and distance (f32).\n            let hnsw_id = neighbour.d_id as u64;\n            let distance = neighbour.distance;\n\n            // Look up UUID from HNSW ID\n            let uuid_str = match h2u_table.get(hnsw_id) {\n                Ok(Some(v)) => v.value().to_string(),\n                _ => continue,\n            };\n\n            // Look up entry from UUID\n            let entry_bytes = match entries_table.get(uuid_str.as_str()) {\n                Ok(Some(v)) => v.value().to_vec(),\n                _ => continue,\n            };\n\n            let entry: KnowledgeEntry = match serde_json::from_slice(&entry_bytes) {\n                Ok(e) => e,\n                Err(_) => continue,\n            };\n\n            // Post-filter by scope\n            if entry.scope_id != scope_id {\n                continue;\n            }\n\n            let score = 1.0 - distance; // cosine distance → similarity\n            results.push(SearchResult { entry, score });\n\n            if results.len() >= limit {\n                break;",
