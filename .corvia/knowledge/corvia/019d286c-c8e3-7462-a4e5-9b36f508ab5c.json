{
  "id": "019d286c-c8e3-7462-a4e5-9b36f508ab5c",
  "content": "/div>\n  <div class=\"slide-title\">\n    Same Mistakes.<br>\n    <span class=\"highlight-amber\">Every Time.</span>\n  </div>\n  <div class=\"slide-subtitle\">\n    After dozens of iterations, the same four<br>\n    categories of visual errors kept appearing.\n  </div>\n  <div style=\"display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px;\">\n    <div style=\"display: flex; gap: 20px;\">\n      <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-left: 4px solid var(--accent-red);\">\n        <div style=\"font-size: 36px; margin-bottom: 8px;\">&#128196;</div>\n        <h3 style=\"font-size: 22px; font-weight: 700; margin-bottom: 8px;\">Text Overflow</h3>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.5;\">\n          Long labels spill out of fixed-width containers.\n        </div>\n      </div>\n      <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-left: 4px solid var(--accent-amber);\">\n        <div style=\"font-size: 36px; margin-bottom: 8px;\">&#128204;</div>\n        <h3 style=\"font-size: 22px; font-weight: 700; margin-bottom: 8px;\">Element Overlap</h3>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.5;\">\n          Absolute positioning without checking neighbors.\n        </div>\n      </div>\n    </div>\n    <div style=\"display: flex; gap: 20px;\">\n      <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-left: 4px solid var(--accent-purple);\">\n        <div style=\"font-size: 36px; margin-bottom: 8px;\">&#128200;</div>\n        <h3 style=\"font-size: 22px; font-weight: 700; margin-bottom: 8px;\">Misaligned Diagrams</h3>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.5;\">\n          Flow arrows that don't connect. Boxes at different heights.\n        </div>\n      </div>\n      <div class=\"card\" style=\"flex: 1; margin-bottom: 0; border-left: 4px solid var(--accent-cyan);\">\n        <div style=\"font-size: 36px; margin-bottom: 8px;\">&#128690;</div>\n        <h3 style=\"font-size: 22px; font-weight: 700; margin-bottom: 8px;\">Grid Collapse</h3>\n        <div style=\"font-size: 18px; color: var(--text-secondary); line-height: 1.5;\">\n          4-column grid collapses to one. Side by side becomes stacked.\n        </div>\n      </div>\n    </div>\n  </div>",
