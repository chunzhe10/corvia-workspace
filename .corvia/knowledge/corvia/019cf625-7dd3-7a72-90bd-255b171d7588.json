  "content": "# corvia-workspace — toggle optional devcontainer services\n# Usage: corvia-workspace {enable|disable|status} [ollama|surrealdb]\n\n# Ensure flags file exists with defaults\ninit_flags() {\n    if [ ! -f \"$FLAGS_FILE\" ]; then\n        cat > \"$FLAGS_FILE\" <<'EOF'\nollama=disabled\nsurrealdb=disabled\nEOF\n    fi\n}\n\nget_flag() {\n    init_flags\n    grep \"^$1=\" \"$FLAGS_FILE\" | cut -d= -f2\n}\n\nset_flag() {\n    init_flags\n    if grep -q \"^$1=\" \"$FLAGS_FILE\"; then\n        sed -i \"s/^$1=.*/$1=$2/\" \"$FLAGS_FILE\"\n    else\n        echo \"$1=$2\" >> \"$FLAGS_FILE\"\n    fi\n}\n\n\n# --- Ollama ---\n\nenable_ollama() {\n    echo \"Enabling Ollama...\"\n",
