  "content": "     // Step 2: Start if not running\n        if !self.is_running().await {\n            Self::start()?;\n            self.wait_ready(10).await?;\n        }\n\n        // Step 3: Pull model if needed\n        self.pull_model(model).await?;\n\n        Ok(())\n    }\n}\npub fn new(url: &str) -> Self {\n        Self {\n            url: url.to_string(),\n        }\n    }",
