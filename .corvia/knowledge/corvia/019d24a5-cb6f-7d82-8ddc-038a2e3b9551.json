{
  "id": "019d24a5-cb6f-7d82-8ddc-038a2e3b9551",
  "content": " {\n        let assignments = kmeans_with_rng(data, k, 100, rng);\n        let score = silhouette_score_with_rng(data, &assignments, k, rng);\n        if score > best_score {\n            best_score = score;\n            best_k = k;\n        }\n    }\n    best_k\n}\nfn compute_centroid(vectors: &[&Vec<f32>]) -> Vec<f32> {\n    let dim = vectors[0].len();\n    let mut centroid = vec![0.0f32; dim];\n    for v in vectors {\n        for (j, val) in v.iter().enumerate() {\n            centroid[j] += val;\n        }\n    }\n    let n = vectors.len() as f32;\n    centroid.iter_mut().for_each(|x| *x /= n);\n    centroid\n}",
