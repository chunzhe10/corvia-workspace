{
  "id": "019d286a-f2d4-7b31-a785-d4c41e4099b3",
  "content": "in &super_clusters {\n            if sc.entry_ids.len() < 4 {\n                continue; // Too small to sub-divide\n            }\n            let sc_embeddings: Vec<Vec<f32>> = sc\n                .entry_ids\n                .iter()\n                .map(|id| {\n                    entries\n                        .iter()\n                        .find(|(eid, _)| eid == id)\n                        .unwrap()\n                        .1\n                        .clone()\n                })\n                .collect();\n            let sc_entries: Vec<(String, Vec<f32>)> = sc\n                .entry_ids\n                .iter()\n                .zip(sc_embeddings.iter())\n                .map(|(id, e)| (id.clone(), e.clone()))\n                .collect();\n\n            let sub_k_max = (sc.entry_ids.len() / 2).clamp(2, 8);\n            let sub_k = find_best_k_with_rng(&sc_embeddings, 2, sub_k_max, 200, rng);\n            let sub_assignments = kmeans_with_rng(&sc_embeddings, sub_k, 100, rng);\n\n            for s in 0..sub_k {\n                let member_indices: Vec<usize> = sub_assignments\n                    .iter()\n                    .enumerate()\n                    .filter(|&(_, a)| *a == s)\n                    .map(|(i, _)| i)\n                    .collect();\n                if member_indices.is_empty() {\n                    continue;\n                }\n\n                let entry_ids: Vec<String> =\n                    member_indices.iter().map(|&i| sc_entries[i].0.clone()).collect();\n                let centroid = compute_centroid(\n                    &member_indices\n                        .iter()\n                        .map(|&i| &sc_embeddings[i])",
