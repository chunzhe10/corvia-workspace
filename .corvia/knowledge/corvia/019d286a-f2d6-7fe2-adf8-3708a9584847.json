{
  "id": "019d286a-f2d6-7fe2-adf8-3708a9584847",
  "content": " assert!(content_references_symbol(\"use LiteStore;\", \"LiteStore\"));\n\n        // \"LiteStore\" should NOT match in \"use LiteStoreExtra;\"\n        assert!(!content_references_symbol(\n            \"use LiteStoreExtra;\",\n            \"LiteStore\"\n        ));\n    }\n}\nimpl ChunkingStrategy for LineChunker {\n        fn name(&self) -> &str {\n            \"line_chunker\"\n        }\n\n        fn supported_extensions(&self) -> &[&str] {\n            &[\"txt\", \"log\"]\n        }\n\n        fn chunk(&self, source: &str, meta: &SourceMetadata) -> Result<crate::chunking_strategy::ChunkResult> {\n            let chunks = source\n                .lines()\n                .enumerate()\n                .map(|(i, line)| RawChunk {\n                    content: line.to_string(),\n                    chunk_type: \"line\".into(),\n                    start_line: (i + 1) as u32,\n                    end_line: (i + 1) as u32,\n                    metadata: ChunkMetadata {\n                        source_file: meta.file_path.clone(),\n                        language: meta.language.clone(),\n                        ..Default::default()\n                    },\n                })\n                .collect();\n            Ok(crate::chunking_strategy::ChunkResult { chunks, relations: vec![] })\n        }\n    }",
  "source_version": "crates/corvia-kernel/src/chunking_pipeline.rs",
  "scope_id": "corvia",
  "workstream": "kernel",
