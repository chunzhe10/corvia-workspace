  "content": "         .fold(f32::MAX, f32::min);\n\n        if b == f32::MAX {\n            continue;\n        }\n        let s = (b - a) / a.max(b);\n        total += s;\n        counted += 1;\n    }\n    if counted == 0 {\n        return 0.0;\n    }\n    total / counted as f32\n}\npub fn find_best_k(data: &[Vec<f32>], k_min: usize, k_max: usize, _max_sample: usize) -> usize {\n    find_best_k_with_rng(data, k_min, k_max, _max_sample, &mut rand::thread_rng())\n}",
