{
  "id": "019d286a-f2d8-78b2-92cd-5439cff2cd9c",
  "content": "## Task 4: Retriever Trait + VectorRetriever\n\n    use crate::lite_store::LiteStore;\n    use corvia_common::types::KnowledgeEntry;\n\n    struct MockEngine;\n    #[async_trait]\n    impl InferenceEngine for MockEngine {\n        async fn embed(&self, _text: &str) -> corvia_common::errors::Result<Vec<f32>> {\n            Ok(vec![1.0, 0.0, 0.0])\n        }\n        async fn embed_batch(&self, texts: &[String]) -> corvia_common::errors::Result<Vec<Vec<f32>>> {\n            Ok(texts.iter().map(|_| vec![1.0, 0.0, 0.0]).collect())\n        }\n        fn dimensions(&self) -> usize { 3 }\n    }\n\n    #[tokio::test]\n    async fn test_vector_retriever_basic_search() {\n        let dir = tempfile::tempdir().unwrap();\n        let store = Arc::new(LiteStore::open(dir.path(), 3).unwrap()) as Arc<dyn QueryableStore>;\n        let engine = Arc::new(MockEngine) as Arc<dyn InferenceEngine>;\n        store.init_schema().await.unwrap();\n\n        // Insert entries with slightly varied embeddings for HNSW connectivity\n        let mut idx = 0_usize;\n        let mut next_emb = || { idx += 1; vec![1.0, idx as f32 * 0.001, 0.0] };\n\n        let mut e1 = KnowledgeEntry::new(\"auth module\".into(), \"proj\".into(), \"v1\".into())\n            .with_embedding(next_emb());\n        e1.entry_status = EntryStatus::Merged;\n        store.insert(&e1).await.unwrap();\n\n        let mut e2 = KnowledgeEntry::new(\"database layer\".into(), \"proj\".into(), \"v1\".into())\n            .with_embedding(next_emb());\n        e2.entry_status = EntryStatus::Merged;\n        store.insert(&e2).await.unwrap();\n\n        // Filler for HNSW connectivity\n        for i in 0..8 {\n            let mut f = KnowledgeEntry::new(format!(\"filler-{i}\"), \"proj\".into(), \"v1\".into())\n                .with_embedding(next_emb());",
