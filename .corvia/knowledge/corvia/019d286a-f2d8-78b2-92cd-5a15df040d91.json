  "id": "019d286a-f2d8-78b2-92cd-5a15df040d91",
  "content": "            continue;\n            }\n            walk_dir(&path, skip, exts, scope_id, total, out);\n            continue;\n        }\n\n        let ext = path\n            .extension()\n            .and_then(|e| e.to_str())\n            .map(|e| e.to_lowercase())\n            .unwrap_or_default();\n\n        let name_lower = name_str.to_lowercase();\n        if !exts.contains(ext.as_str()) && !exts.contains(name_lower.as_str()) {\n            continue;\n        }\n\n        let meta = match std::fs::metadata(&path) {\n            Ok(m) => m,\n            Err(_) => continue,\n        };\n\n        if meta.len() > MAX_FILE_SIZE || meta.len() == 0 {\n            continue;\n        }\n\n        let content = match std::fs::read_to_string(&path) {\n            Ok(c) => c,\n            Err(_) => continue,\n        };\n\n        let rel_path = path\n            .strip_prefix(dir.parent().unwrap_or(dir))\n            .unwrap_or(&path)\n            .to_string_lossy()\n            .to_string();\n\n        // Use path relative to the source root, not the parent\n        let rel_from_source = path\n            .strip_prefix(dir)\n            .unwrap_or(&path)\n            .to_string_lossy()\n            .to_string();\n\n        let msg = SourceFileMsg {\n            source_file: SourceFilePayload {\n                content,\n                metadata: SourceMetadata {\n                    file_path: rel_from_source,\n                    extension: ext,\n                    language: None,\n                    scope_id: scope_id.to_string(),\n                    source_version: \"unknown\".into(),\n                },\n            },\n        };\n\n        writeln!(out, \"{}\", serde_json::to_string(&msg).unwrap()).ok();\n        *total += 1;\n    }\n    out.flush().ok();\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use std::fs;\n\n    #[test]\n    fn test_metadata_output() {\n        let meta = metadata();",
