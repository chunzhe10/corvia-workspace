  "id": "019d286a-f2d5-7fe1-8420-81386bac376d",
  "content": "me(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(Some(entries))\n    }\n\n    async fn remove_edges(&self, entry_id: &uuid::Uuid) -> Result<()> {\n        self.graph.remove_edges(entry_id).await\n    }\n}\nasync fn relate(\n        &self,\n        from: &uuid::Uuid,\n        relation: &str,\n        to: &uuid::Uuid,\n        metadata: Option<serde_json::Value>,\n    ) -> Result<()> {\n        self.graph.relate(from, relation, to, metadata).await\n    }",
