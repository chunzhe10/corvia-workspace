  "id": "019d24a5-cb6e-7393-a365-a21b3d32c157",
  "content": "ems\n            .into_iter()\n            .filter(|i| i.topic_tags.contains(topic))\n            .collect()\n    } else {\n        items\n    };\n\n    let total = items.len();\n    Json(ActivityFeedResponse {\n        items,\n        total,\n        topics,\n    })\n}\npub fn group_activity_items(items: &mut [ActivityItem]) {\n    let mut i = 0;\n    while i < items.len() {\n        let mut group_size = 1usize;\n        let mut j = i + 1;\n        while j < items.len() {\n            let same_agent = items[i].agent_id == items[j].agent_id;\n            let same_topic = !items[i].topic_tags.is_empty()\n                && items[i].topic_tags.first()\n                    == items[j].topic_tags.first();\n\n            let time_i: DateTime<Utc> = items[i]\n                .recorded_at\n                .parse()\n                .unwrap_or_default();\n            let time_j: DateTime<Utc> = items[j]\n                .recorded_at\n                .parse()\n                .unwrap_or_default();\n            let within_5min = (time_i - time_j).num_seconds().abs() < 300;\n\n            if same_agent && (same_topic || within_5min) {\n                group_size += 1;\n                j += 1;\n            } else {\n                break;\n            }\n        }\n\n        if group_size > 1 {\n            let group_id = format!(\"group-{i}\");\n            for item in &mut items[i..j] {\n                item.group_id = Some(group_id.clone());\n                item.group_count = Some(group_size);\n            }\n        }\n        i = j;\n    }\n}",
