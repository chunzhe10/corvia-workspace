  "content": "ding = Some(embedding);\n                store.insert(&new_entry).await?;\n            }\n            println!(\"    Created {} entries (supersedes previous)\", chunks.len());\n        }\n        return Ok(());\n    }\n\n    // Existing full ingest logic (unchanged)\n    if let Some(path) = path {\n        cmd_ingest_single(path).await\n    } else {\n        let root = std::env::current_dir()?;\n        workspace::ingest_workspace(&root, None, false).await\n    }\n}\n```\n\n- [ ] **Step 3: Update the match arm**\n\n```rust\nCommands::Ingest { path, incremental, files } =>\n    cmd_ingest(path.as_deref(), incremental, &files).await?,\n```\n\n- [ ] **Step 4: Build and verify CLI help**\n\nRun: `cd /workspaces/corvia-workspace/repos/corvia && cargo build -p corvia-cli`\nExpected: Compiles. `corvia ingest --help` shows `--incremental` and `--files` flags.\n\n- [ ] **Step 5: Write integration test for incremental ingest**\n\nAdd a test that verifies the chunking + store insertion path. Uses `LiteStore` + `MockEngine` (existing test patterns from `tests/integration/`):\n\n```rust\n#[tokio::test]\nasync fn test_incremental_ingest_creates_chunked_entries() {\n    use corvia_kernel::lite_store::LiteStore;\n    use corvia_kernel::chunking_pipeline::ChunkingPipeline;\n    use corvia_kernel::chunking_strategy::SourceMetadata;\n    use corvia_common::config::ChunkingConfig;\n    use corvia_common::types::KnowledgeEntry;\n\n    let dir = tempfile::tempdir().unwrap();\n    let store = LiteStore::open(dir.path(), 768).unwrap();\n    store.init_schema().await.unwrap();\n\n    // Create a test markdown file with two sections\n    let test_file = dir.path().join(\"test.md\");\n    std::fs::write(&test_file, \"# Section 1\\n\\nContent one.\\n\\n# Section 2\\n\\nContent two.\").unwrap();\n\n    // Chunk through the standard pipeline\n    let config = ChunkingConfig::default();",
