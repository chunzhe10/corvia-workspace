  "content": "e::Stale | SessionState::Orphaned)\n            );\n            if has_stale_or_orphaned {\n                reconnectable.push(agent);\n            }\n        }\n        reconnectable.sort_by(|a, b| b.last_seen.cmp(&a.last_seen));\n        Ok(reconnectable)\n    }\npub async fn search(\n        &self,\n        query: &str,\n        scope_id: &str,\n        limit: usize,\n        visibility: &VisibilityMode,\n        agent_id: Option<&str>,\n        permissions: Option<&AgentPermission>,\n    ) -> Result<Vec<SearchResult>> {\n        self.context.search(query, scope_id, limit, visibility, agent_id, permissions).await\n    }",
