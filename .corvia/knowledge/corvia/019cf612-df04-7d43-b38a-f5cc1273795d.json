{
  "id": "019cf612-df04-7d43-b38a-f5cc1273795d",
  "content": "pub fn normalize_level(level: &str) -> &'static str {\n    match level.to_lowercase().as_str() {\n        \"warn\" | \"warning\" => \"warn\",\n        \"error\" | \"err\" => \"error\",\n        \"debug\" | \"trace\" => \"debug\",\n        _ => \"info\",\n    }\n}\npub fn short_timestamp(ts: &str) -> String {\n    if let Some(t_pos) = ts.find('T') {\n        // 'T' is ASCII so t_pos + 1 is always a valid char boundary\n        let rest = &ts[t_pos + 1..];\n        if rest.len() >= 8 && rest.is_char_boundary(8) {\n            return rest[..8].to_string();\n        }\n    }\n    ts.to_string()\n}",
