{
  "id": "019d286a-f2d8-78b2-92cd-42643ff39d19",
  "content": "### Step 1: Write failing tests for new config types\n\n#[test]\nfn test_lite_config_roundtrip() {\n    let config = CorviaConfig::default();\n    config.save(Path::new(\"/tmp/corvia-test-lite.toml\")).unwrap();\n    let loaded = CorviaConfig::load(Path::new(\"/tmp/corvia-test-lite.toml\")).unwrap();\n    assert_eq!(loaded.storage.store_type, StoreType::Lite);\n    assert_eq!(loaded.embedding.provider, InferenceProvider::Ollama);\n}\n\n#[test]\nfn test_full_config_roundtrip() {\n    let config = CorviaConfig::full_default();\n    config.save(Path::new(\"/tmp/corvia-test-full.toml\")).unwrap();\n    let loaded = CorviaConfig::load(Path::new(\"/tmp/corvia-test-full.toml\")).unwrap();\n    assert_eq!(loaded.storage.store_type, StoreType::Surrealdb);\n    assert_eq!(loaded.storage.surrealdb_url, Some(\"127.0.0.1:8000\".into()));\n}\n\n#[test]\nfn test_store_type_serde() {\n    let json = serde_json::to_string(&StoreType::Lite).unwrap();\n    assert_eq!(json, \"\\\"lite\\\"\");\n    let parsed: StoreType = serde_json::from_str(\"\\\"surrealdb\\\"\").unwrap();\n    assert_eq!(parsed, StoreType::Surrealdb);\n}\n```\n",
