  "content": "### Task 4: ConfigChunker\n\n            file_path: \"Cargo.toml\".into(),\n            extension: \"toml\".into(),\n            language: Some(\"toml\".into()),\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    fn json_meta() -> SourceMetadata {\n        SourceMetadata {\n            file_path: \"package.json\".into(),\n            extension: \"json\".into(),\n            language: Some(\"json\".into()),\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    fn yaml_meta() -> SourceMetadata {\n        SourceMetadata {\n            file_path: \"config.yaml\".into(),\n            extension: \"yaml\".into(),\n            language: Some(\"yaml\".into()),\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    #[test]\n    fn test_toml_section_splitting() {\n        let source = \"[package]\\nname = \\\"test\\\"\\nversion = \\\"0.1.0\\\"\\n\\n[dependencies]\\nserde = \\\"1\\\"\\ntokio = \\\"1\\\"\\n\";\n        let chunker = ConfigChunker::new();\n        let chunks = chunker.chunk(source, &toml_meta()).unwrap();\n        assert!(chunks.len() >= 2, \"expected at least 2 TOML sections, got {}\", chunks.len());\n        assert!(chunks[0].content.contains(\"[package]\"));\n        assert!(chunks.iter().any(|c| c.content.contains(\"[dependencies]\")));\n    }\n",
