  "content": "fn extract_session_id(path: &Path) -> Option<String> {\n    path.file_stem()\n        .and_then(|s| s.to_str())\n        .map(|s| s.to_string())\n}\nfn extract_session_id_from_gz(path: &Path) -> Option<String> {\n    let name = path.file_name()?.to_str()?;\n    name.strip_suffix(\".jsonl.gz\").map(|s| s.to_string())\n}",
