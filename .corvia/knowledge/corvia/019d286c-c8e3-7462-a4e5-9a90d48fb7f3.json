  "id": "019d286c-c8e3-7462-a4e5-9a90d48fb7f3",
  "content": "margin: 28px 0;\n  }\n\n  .flex-grow { flex: 1; }\n\n  .cover-center {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .cover-tags {\n    margin-top: 40px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 12px;\n  }\n  .cover-tags .tag {\n    display: inline-block;\n    padding: 10px 20px;\n    border-radius: 20px;\n    font-size: 20px; font-weight: 600;\n    background: rgba(59, 130, 246, 0.15);\n    color: var(--accent-blue);\n  }\n\n  .insight-box {\n    background: rgba(16, 185, 129, 0.08);\n    border: 1px solid rgba(16, 185, 129, 0.25);\n    border-radius: 16px;\n    padding: 24px 28px;\n    margin: 16px 0;\n  }\n\n  .insight-box p {\n    font-size: 22px; font-weight: 500;\n    color: var(--accent-green);\n    line-height: 1.5;\n  }\n\n  .stat-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin: 24px 0;\n  }\n\n  .stat-box {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 28px;\n    text-align: center;\n  }\n\n  .stat-value {\n    font-size: 48px; font-weight: 800;\n    margin-bottom: 8px;\n  }\n\n  .stat-label {\n    font-size: 18px; font-weight: 500;\n    color: var(--text-secondary);\n  }\n\n  .takeaway-list {\n    display: flex;\n    flex-direction: column;\n    gap: 28px;\n    margin: 16px 0;\n  }\n\n  .takeaway-item {\n    display: flex;\n    align-items: flex-start;\n    gap: 20px;\n  }\n\n  .takeaway-icon {\n    font-size: 32px;\n    flex-shrink: 0;\n    margin-top: 2px;\n  }\n\n  .takeaway-text {\n    font-size: 24px; font-weight: 500;\n    line-height: 1.5;\n  }\n\n  .takeaway-text strong { font-weight: 700; }\n\n  .mock-label {\n    font-size: 16px; font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    margin-bottom: 12px;\n  }\n</style>\n</head>\n<body>",
