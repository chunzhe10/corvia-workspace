  "content": "pub trait TokenEstimator: Send + Sync {\n    fn estimate(&self, text: &str) -> usize;\n}\nimpl TokenEstimator for CharDivFourEstimator {\n    fn estimate(&self, text: &str) -> usize {\n        if text.is_empty() {\n            0\n        } else {\n            (text.len() / 4).max(1)\n        }\n    }\n}",
