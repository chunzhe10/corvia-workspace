  "content": "accumulator.is_empty() {\n            result.push(accumulator);\n        }\n\n        result\n    }\n\n    /// Count the number of `\\n` characters in a string.\n    fn newline_count(s: &str) -> u32 {\n        s.bytes().filter(|&b| b == b'\\n').count() as u32\n    }\n}\npub fn new(max_tokens: usize) -> Self {\n        Self { max_tokens }\n    }",
