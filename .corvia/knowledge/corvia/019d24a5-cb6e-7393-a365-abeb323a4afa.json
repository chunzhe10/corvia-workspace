  "content": "pub fn subscribe(&self) -> broadcast::Receiver<HookSessionUpdate> {\n        self.tx.subscribe()\n    }\nfn broadcast(&self, update: HookSessionUpdate) {\n        // Ignore send error — means no active subscribers.\n        let _ = self.tx.send(update);\n    }",
