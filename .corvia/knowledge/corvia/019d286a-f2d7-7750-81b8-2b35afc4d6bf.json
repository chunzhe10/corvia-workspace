{
  "id": "019d286a-f2d7-7750-81b8-2b35afc4d6bf",
  "content": "_meta()).unwrap();\n        assert!(chunks.len() >= 2, \"expected at least 2 TOML sections, got {}\", chunks.len());\n        assert!(chunks[0].content.contains(\"[package]\"));\n        assert!(chunks.iter().any(|c| c.content.contains(\"[dependencies]\")));\n    }\n\n    #[test]\n    fn test_json_top_level_keys() {\n        let source = r#\"{\"name\": \"test\", \"version\": \"1.0\", \"scripts\": {\"build\": \"cargo build\"}, \"dependencies\": {\"serde\": \"1\"}}\"#;\n        let chunker = ConfigChunker::new();\n        let chunks = chunker.chunk(source, &json_meta()).unwrap();\n        assert!(!chunks.is_empty());\n    }\n\n    #[test]\n    fn test_yaml_top_level_keys() {\n        let source = \"name: test\\nversion: 1.0\\n\\nservices:\\n  web:\\n    port: 8080\\n  db:\\n    port: 5432\\n\";\n        let chunker = ConfigChunker::new();\n        let chunks = chunker.chunk(source, &yaml_meta()).unwrap();\n        assert!(!chunks.is_empty());\n    }\n\n    #[test]\n    fn test_empty_config() {\n        let chunker = ConfigChunker::new();\n        let chunks = chunker.chunk(\"\", &toml_meta()).unwrap();\n        assert!(chunks.is_empty());\n    }\n\n    #[test]\n    fn test_chunk_type_is_key_section() {\n        let source = \"[package]\\nname = \\\"test\\\"\\n\";\n        let chunker = ConfigChunker::new();\n        let chunks = chunker.chunk(source, &toml_meta()).unwrap();\n        assert!(!chunks.is_empty());\n        assert!(chunks[0].chunk_type == \"section\" || chunks[0].chunk_type == \"key_section\");\n    }\n\n    #[test]\n    fn test_name_and_extensions() {\n        let chunker = ConfigChunker::new();\n        assert_eq!(chunker.name(), \"config\");\n        assert_eq!(chunker.supported_extensions(), &[\"toml\", \"yaml\", \"yml\", \"json\"]);\n    }",
