  "content": "fn json_str(v: &serde_json::Value, key: &str) -> String {\n    v.get(key)\n        .and_then(|v| v.as_str())\n        .unwrap_or(\"\")\n        .to_string()\n}\nfn json_str_or(v: &serde_json::Value, key: &str, default: &str) -> String {\n    v.get(key)\n        .and_then(|v| v.as_str())\n        .unwrap_or(default)\n        .to_string()\n}",
