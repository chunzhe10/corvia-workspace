  "id": "019d286c-c8e3-7462-a4e5-a73a78f117cc",
  "content": "with two sections\n    let test_file = dir.path().join(\"test.md\");\n    std::fs::write(&test_file, \"# Section 1\\n\\nContent one.\\n\\n# Section 2\\n\\nContent two.\").unwrap();\n\n    // Chunk through the standard pipeline\n    let config = ChunkingConfig::default();\n    let pipeline = ChunkingPipeline::with_kernel_defaults(config);\n    let content = std::fs::read_to_string(&test_file).unwrap();\n    let meta = SourceMetadata {\n        file_path: test_file.to_string_lossy().to_string(),\n        extension: \"md\".to_string(),\n        language: None,\n        scope_id: \"test\".to_string(),\n        source_version: \"v1\".to_string(),\n    };\n    let (chunks, _relations) = pipeline.process(&content, &meta).unwrap();\n    assert!(!chunks.is_empty(), \"chunking should produce at least 1 chunk\");\n\n    // Insert each chunk as an entry (skip real embedding — use fake)\n    let fake_embedding = vec![0.1_f32; 768];\n    for chunk in &chunks {\n        let mut entry = KnowledgeEntry::new(\n            chunk.content.clone(), \"test\".into(), \"v1\".into(),\n        );\n        entry.metadata.source_file = Some(test_file.to_string_lossy().to_string());\n        entry.metadata.chunk_type = Some(chunk.processing.strategy_name.clone());\n        entry.embedding = Some(fake_embedding.clone());\n        store.insert(&entry).await.unwrap();\n    }\n\n    // Verify entries were stored\n    let count = store.count(\"test\").await.unwrap();\n    assert_eq!(count, chunks.len(), \"store should contain one entry per chunk\");\n}\n```\n\nThe key assertions are:\n- Chunking pipeline produces multiple chunks from a multi-section markdown file\n- Each chunk is stored as a separate entry with correct `source_file` and `chunk_type` metadata\n- Entry count in the store matches chunk count\n\n- [ ] **Step 6: Commit**\n\n```bash\ncd /workspaces/corvia-workspace/repos/corvia\ngit add crates/corvia-cli/src/main.rs\ngit commit -m \"feat(cli): add --incremental --files flags to ingest command\"\n```\n\n---\n",
