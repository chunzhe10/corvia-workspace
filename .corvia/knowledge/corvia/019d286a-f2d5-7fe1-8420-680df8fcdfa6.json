  "id": "019d286a-f2d5-7fe1-8420-680df8fcdfa6",
  "content": "pub fn url(&self) -> &str {\n        &self.base_url\n    }\npub async fn search(\n        &self,\n        query: &str,\n        scope_id: &str,\n        limit: usize,\n    ) -> Result<SearchResponse> {\n        let resp = self\n            .client\n            .post(format!(\"{}/v1/memories/search\", self.base_url))\n            .json(&SearchRequest {\n                query: query.to_string(),\n                scope_id: scope_id.to_string(),\n                limit: Some(limit),\n            })\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }",
