  "id": "019d286a-f2d7-7750-81b8-32b360aa2131",
  "content": "## Trait Definitions\n\n### Stage 1: Retriever\n\n```rust\n#[async_trait]\npub trait Retriever: Send + Sync {\n    /// Identifier for metrics attribution and eval benchmarking.\n    fn name(&self) -> &str;\n\n    /// Retrieve entries relevant to a query within a scope.\n    async fn retrieve(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: &RetrievalOpts,\n    ) -> Result<RetrievalResult>;\n}\n```\n\n\n### Stage 2: Augmenter\n\n```rust\npub trait Augmenter: Send + Sync {\n    /// Identifier for metrics attribution and eval benchmarking.\n    fn name(&self) -> &str;\n\n    /// Format search results into a context string for LLM consumption.\n    fn augment(\n        &self,\n        query: &str,\n        results: &[SearchResult],\n        budget: &TokenBudget,\n    ) -> Result<AugmentedContext>;\n}\n```\n",
