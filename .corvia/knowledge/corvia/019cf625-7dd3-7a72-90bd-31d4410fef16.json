  "content": "\"purpose\": \"The difference — tangible improvement\",\n        \"template\": \"before-after\"\n      },\n      {\n        \"position\": \"last\",\n        \"purpose\": \"Key lessons + engagement CTA\",\n        \"template\": \"takeaway\"\n      }\n    ]\n  },\n  \"slideTemplates\": {\n    \"_description\": \"Canonical slide types for LinkedIn carousels. AI should compose slides from these templates rather than generating arbitrary layouts. Each template defines its structure, content constraints, and height budget within the 936x1110px safe area.\",\n    \"before-after\": {\n      \"description\": \"Two-column comparison of workflow/results before and after the solution.\",\n      \"rules\": [\n        \"Left card: red top border, icon (36px), red heading (22px), bullet list (20px, 5 items max)\",\n        \"Right card: green top border, icon (36px), green heading (22px), bullet list (20px, 5 items max)\",\n        \"Bullet lists use secondary color, line-height 1.8\",\n        \"Related topics: small colored cards with label (20px bold) + description (18px)\",\n        \"Insight box ties together the 'so what' message\"\n      ],\n      \"structure\": [\n        {\n          \"element\": \"slide-label\"\n        },\n        {\n          \"element\": \"title\",\n          \"font\": \"slideTitle (58px)\",\n          \"heightBudget\": 140,\n          \"maxLines\": 2\n        },\n        {\n          \"element\": \"subtitle\",\n          \"font\": \"subtitle (28px)\",\n          \"heightBudget\": 45,\n          \"maxLines\": 1\n        },\n        {\n          \"element\": \"comparison-cards\",\n          \"heightBudget\": 380,\n          \"layout\": \"flex row, 2 equal cards\"\n        },\n        {\n          \"element\": \"divider\"\n        },\n        {\n          \"element\": \"related-topics\",",
