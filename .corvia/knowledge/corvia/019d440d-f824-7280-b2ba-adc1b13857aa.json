  "content": "fn test_truncate_str_exact_boundary() {\n        let (s, t) = truncate_str(\"hello\", 5);\n        assert_eq!(s, \"hello\");\n        assert!(!t);\n    }\nfn test_now_iso_format() {\n        let ts = now_iso();\n        assert!(ts.ends_with('Z'));\n        assert!(ts.contains('T'));\n        assert_eq!(ts.len(), 30); // YYYY-MM-DDTHH:MM:SS.nnnnnnnnnZ\n    }",
