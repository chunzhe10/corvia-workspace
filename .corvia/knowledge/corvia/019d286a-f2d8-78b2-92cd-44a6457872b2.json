  "content": "   let write_txn = self.db.begin_write()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb write error: {e}\")))?;\n        {\n            let mut table = write_txn.open_table(META)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n            table.insert(\"next_hnsw_id\", self.next_hnsw_id.load(Ordering::SeqCst))\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n        }\n        write_txn.commit()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb commit error: {e}\")))?;\n        Ok(())\n    }\n\n    /// Flush HNSW index to disk for persistence.\n    pub fn flush_hnsw(&self) -> Result<()> {\n        let hnsw = self.hnsw.lock().unwrap();\n        hnsw.file_dump(&self.data_dir, \"index\")\n            .map_err(|e| CorviaError::Storage(format!(\"Failed to dump HNSW index: {e}\")))?;\n        info!(\"HNSW index flushed to disk\");\n        Ok(())\n    }\n\n    /// Internal: index an entry into HNSW + Redb (without writing JSON file).\n    fn index_entry(&self, entry: &KnowledgeEntry, embedding: &[f32]) -> Result<()> {\n        let hnsw_id = self.allocate_hnsw_id();\n        let uuid_str = entry.id.to_string();\n\n        // Insert into HNSW\n        {",
