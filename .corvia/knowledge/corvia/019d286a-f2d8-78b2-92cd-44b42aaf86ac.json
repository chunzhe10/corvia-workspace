{
  "id": "019d286a-f2d8-78b2-92cd-44b42aaf86ac",
  "content": "HNSW + Redb (without writing JSON file).\n    fn index_entry(&self, entry: &KnowledgeEntry, embedding: &[f32]) -> Result<()> {\n        let hnsw_id = self.allocate_hnsw_id();\n        let uuid_str = entry.id.to_string();\n\n        // Insert into HNSW\n        {\n            let hnsw = self.hnsw.lock().unwrap();\n            let data = embedding.to_vec();\n            hnsw.insert((&data, hnsw_id as usize));\n        }\n\n        // Insert into Redb\n        let entry_json = serde_json::to_vec(entry)\n            .map_err(|e| CorviaError::Storage(format!(\"Serialize error: {e}\")))?;\n\n        let write_txn = self.db.begin_write()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb write error: {e}\")))?;\n        {\n            let mut entries_table = write_txn.open_table(ENTRIES)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n            entries_table.insert(uuid_str.as_str(), entry_json.as_slice())\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n            let mut scope_table = write_txn.open_table(SCOPE_INDEX)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n            let scope_key = format!(\"{}:{}\", entry.scope_id, uuid_str);\n            scope_table.insert(scope_key.as_str(), uuid_str.as_str())\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n            let mut h2u = write_txn.open_table(HNSW_TO_UUID)",
  "source_version": "docs/rfcs/2026-03-01-m1.2-litestore.md",
