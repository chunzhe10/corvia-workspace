  "content": "st_chunker -- --nocapture`\nExpected: All tests PASS\n\n**Step 5: Commit**\n\n```bash\ngit add corvia-adapter-git/src/ast_chunker.rs corvia-adapter-git/src/lib.rs\ngit commit -m \"feat(m3.3): AstChunker — tree-sitter ChunkingStrategy adapter (D65/D68)\"\n```\n\n---\n\n### Task 9: Update GitAdapter for D69 Trait\n\nImplement the revised `IngestionAdapter` trait on `GitAdapter`.\n\n**Files:**\n- Modify: `corvia-adapter-git/src/git.rs` (implement new trait methods)\n- Modify: `corvia-adapter-git/src/lib.rs` (update exports)\n\n**Step 1: Write the failing test**\n\nAdd test to `corvia-adapter-git/src/git.rs`:\n\n```rust\n#[tokio::test]\nasync fn test_ingest_sources_returns_source_files() {\n    let dir = TempDir::new().unwrap();\n    let src_dir = dir.path().join(\"src\");\n    fs::create_dir_all(&src_dir).unwrap();\n    fs::write(src_dir.join(\"lib.rs\"), \"fn hello() {\\n    42\\n}\\n\").unwrap();\n    fs::write(dir.path().join(\"README.md\"), \"# Hello\\n\\nWorld.\\n\").unwrap();\n\n    let adapter = GitAdapter::new();\n    let files = adapter.ingest_sources(dir.path().to_str().unwrap()).await.unwrap();\n    assert!(files.len() >= 2, \"expected at least 2 source files, got {}\", files.len());\n\n    // Verify SourceFile structure\n    let rs_file = files.iter().find(|f| f.metadata.extension == \"rs\");\n    assert!(rs_file.is_some(), \"should include .rs file\");\n    let rs = rs_file.unwrap();\n    assert!(rs.content.contains(\"fn hello\"));\n    assert!(rs.metadata.file_path.contains(\"lib.rs\"));\n}\n\n#[test]\nfn test_register_chunking_adds_ast_strategy() {\n    use corvia_kernel::chunking_pipeline::FormatRegistry;",
