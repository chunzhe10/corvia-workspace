{
  "id": "019d286a-f2d6-7fe2-adf8-52178e09ff59",
  "content": "h() stub should return None\"\n        );\n\n        // But shortest_path_ids() returns the correct path\n        let path_ids = store.shortest_path_ids(&a, &c).unwrap();\n        assert!(path_ids.is_some());\n        assert_eq!(path_ids.unwrap().len(), 3);\n    }\nasync fn test_remove_edges() {\n        let db = test_db();\n        let store = LiteGraphStore::new(db).unwrap();\n\n        let a = Uuid::now_v7();\n        let b = Uuid::now_v7();\n        store.relate(&a, \"imports\", &b, None).await.unwrap();\n        assert_eq!(\n            store.edges(&a, EdgeDirection::Outgoing).await.unwrap().len(),\n            1\n        );\n\n        store.remove_edges(&a).await.unwrap();\n        assert_eq!(\n            store.edges(&a, EdgeDirection::Outgoing).await.unwrap().len(),\n            0\n        );\n        // b's incoming edge should also be gone\n        assert_eq!(\n            store.edges(&b, EdgeDirection::Incoming).await.unwrap().len(),\n            0\n        );\n    }",
