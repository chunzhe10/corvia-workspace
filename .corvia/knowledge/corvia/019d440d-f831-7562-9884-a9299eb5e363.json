  "content": "pub fn new() -> Self {\n        Self {\n            factories: HashMap::new(),\n        }\n    }\npub fn register<F>(&mut self, name: impl Into<String>, factory: F)\n    where\n        F: Fn(&ComponentDeps) -> Result<Arc<T>> + Send + Sync + 'static,\n    {\n        self.factories.insert(name.into(), Box::new(factory));\n    }",
