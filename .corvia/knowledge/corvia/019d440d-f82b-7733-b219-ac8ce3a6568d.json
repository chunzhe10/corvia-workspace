  "content": "fn home_dir() -> Option<PathBuf> {\n    std::env::var(\"HOME\").ok().map(PathBuf::from)\n}\nfn shellexpand_home(path: &str) -> PathBuf {\n    if let Some(rest) = path.strip_prefix(\"~/\")\n        && let Some(home) = home_dir() {\n            return home.join(rest);\n        }\n    PathBuf::from(path)\n}",
