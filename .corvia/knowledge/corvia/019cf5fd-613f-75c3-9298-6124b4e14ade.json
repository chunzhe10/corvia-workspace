{
  "id": "019cf5fd-613f-75c3-9298-6124b4e14ade",
  "content": "         .fold(f32::MAX, f32::min);\n\n        if b == f32::MAX {\n            continue;\n        }\n        let s = (b - a) / a.max(b);\n        total += s;\n        counted += 1;\n    }\n    if counted == 0 {\n        return 0.0;\n    }\n    total / counted as f32\n}\npub fn find_best_k(data: &[Vec<f32>], k_min: usize, k_max: usize, _max_sample: usize) -> usize {\n    let mut best_k = k_min;\n    let mut best_score = f32::NEG_INFINITY;\n    for k in k_min..=k_max {\n        let assignments = kmeans(data, k, 100);\n        let score = silhouette_score(data, &assignments, k);\n        if score > best_score {\n            best_score = score;\n            best_k = k;\n        }\n    }\n    best_k\n}",
