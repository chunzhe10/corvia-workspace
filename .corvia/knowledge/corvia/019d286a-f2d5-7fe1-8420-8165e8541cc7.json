  "id": "019d286a-f2d5-7fe1-8420-8165e8541cc7",
  "content": "averse_ids(start, relation, direction, max_depth)?;\n        let mut entries = Vec::new();\n        for id in ids {\n            if let Some(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(entries)\n    }\nasync fn shortest_path(\n        &self,\n        from: &uuid::Uuid,\n        to: &uuid::Uuid,\n    ) -> Result<Option<Vec<KnowledgeEntry>>> {\n        let ids = match self.graph.shortest_path_ids(from, to)? {\n            Some(ids) => ids,\n            None => return Ok(None),\n        };\n        let mut entries = Vec::new();\n        for id in ids {\n            if let Some(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(Some(entries))\n    }",
