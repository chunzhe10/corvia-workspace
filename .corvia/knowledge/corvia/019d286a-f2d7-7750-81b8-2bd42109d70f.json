  "content": "### Task 8: AstChunker (corvia-adapter-git)\n\n        SourceMetadata {\n            file_path: \"src/lib.rs\".into(),\n            extension: \"rs\".into(),\n            language: Some(\"rust\".into()),\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    fn py_meta() -> SourceMetadata {\n        SourceMetadata {\n            file_path: \"app.py\".into(),\n            extension: \"py\".into(),\n            language: Some(\"python\".into()),\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    #[test]\n    fn test_rust_function_chunks() {\n        let source = \"fn hello() {\\n    println!(\\\"hello\\\");\\n}\\n\\nfn world() {\\n    println!(\\\"world\\\");\\n}\\n\";\n        let chunker = AstChunker::new();\n        let chunks = chunker.chunk(source, &rust_meta()).unwrap();\n        assert_eq!(chunks.len(), 2);\n        assert!(chunks[0].content.contains(\"hello\"));\n        assert!(chunks[1].content.contains(\"world\"));\n        assert_eq!(chunks[0].chunk_type, \"function_item\");\n    }\n\n    #[test]\n    fn test_python_class_chunks() {\n        let source = \"class MyClass:\\n    def method(self):\\n        pass\\n\\ndef standalone():\\n    return 42\\n\";\n        let chunker = AstChunker::new();\n        let chunks = chunker.chunk(source, &py_meta()).unwrap();\n        assert!(chunks.len() >= 2);\n    }\n\n    #[test]\n    fn test_unsupported_extension_returns_whole_file() {\n        let meta = SourceMetadata {\n            file_path: \"data.txt\".into(),\n            extension: \"txt\".into(),",
